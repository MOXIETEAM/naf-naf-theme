{%- doc -%}
  Link de utilidad del footer del drawer mobile (ej. Ubicación / Mi Cuenta / Ayuda).

  Hijo de `_custom_menu`. Solo visible dentro del drawer: en la copia desktop del menú queda
  oculto vía CSS (position absolute + visibility hidden — NO display:none, para que overflow-list
  lo cuente como visible de forma estable y nunca lo mueva al slot "More"; ver
  src/styles/components/_header-drawer.scss).

  "Rastrear Mi Pedido" y "Favoritos" quedaron fuera de alcance por ahora (decisión 2026-07-06);
  cuando existan, se agregan como instancias de este mismo bloque apuntando a la app que
  corresponda.
{%- enddoc -%}

{% liquid
  assign util_settings = block.settings
  if util_settings.link != blank
    assign util_tag = 'a'
  else
    assign util_tag = 'span'
  endif
%}

<li class="custom-menu-utility-link" {{ block.shopify_attributes }}>
  <{{ util_tag }}
    {% if util_settings.link != blank %}
      href="{{ util_settings.link }}"
    {% endif %}
    class="custom-menu-utility-link__inner"
  >
    {%- if util_settings.icon != 'none' -%}
      <span class="custom-menu-utility-link__icon">
        {{- util_settings.icon | append: '.svg' | inline_asset_content -}}
      </span>
    {%- endif -%}
    <span class="custom-menu-utility-link__text">{{ util_settings.text }}</span>
  </{{ util_tag }}>
</li>

{% schema %}
{
  "name": "Moxie Link de utilidad",
  "tag": null,
  "settings": [
    {
      "type": "select",
      "id": "icon",
      "label": "Ícono",
      "options": [
        {
          "value": "none",
          "label": "Ninguno"
        },
        {
          "value": "ubicacion_home",
          "label": "Ubicación"
        },
        {
          "value": "mi_cuenta_home",
          "label": "Cuenta"
        },
        {
          "value": "ayuda_home",
          "label": "Ayuda"
        },
        {
          "value": "mundo_home",
          "label": "Mundo"
        }
      ],
      "default": "none"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Texto",
      "default": "Enlace"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Enlace"
    }
  ]
}
{% endschema %}

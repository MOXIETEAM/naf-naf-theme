{%- doc -%}
  Contenedor del menú custom Moxie (mega menu desktop + drawer mobile).

  Reemplaza al block nativo `_header-menu` en `sections/custom_header-main.liquid`. Se renderiza
  como static block DOS veces con el mismo id y distinta variant (patrón nativo de Horizon,
  documentado como válido por el check UniqueStaticBlockId de Theme Check):
    - default  → mega menu desktop (<header-menu> + overflow-list, contrato de assets/header-menu.js)
    - 'mobile' → drawer con tabs (<custom-header-drawer>, Fase 2 / Hito 4)

  Los bloques hijos (_custom_menu-item) se configuran UNA vez en el Theme Editor y se renderizan
  en ambas variantes: `content_for 'blocks'` no acepta params custom, así que los hijos son
  agnósticos a la variante — se capturan una sola vez antes del case y cada variante los envuelve
  en su propio contexto (CSS/JS adaptan por contenedor).

  @param {string} [variant] - Qué versión del menú renderizar. Default: mega menu desktop.
{%- enddoc -%}

{% liquid
  assign block_settings = block.settings
  assign effective_submenu_color = block_settings.background_color | default: settings.page_background_color

  render 'contrast-override', background_color: block_settings.background_color, text_color: block_settings.text_color, section_id: block.id

  assign background_color_classes = ''
  assign background_color_setting_id = 'background_color_' | append: section.settings.menu_row
  assign current_background_color = block_settings.background_color | default: settings.page_background_color
  assign parent_background_color = section.settings[background_color_setting_id] | default: settings.page_background_color

  if parent_background_color != current_background_color or block_settings.text_color != blank
    assign background_color_classes = ' color-custom-' | append: block.id
  endif

  if parent_background_color.rgb == current_background_color.rgb
    assign background_color_classes = background_color_classes | append: ' background-matches-parent'
  endif
%}

{% capture children %}
  {% content_for 'blocks' %}
{% endcapture %}

{% case variant %}
  {% when 'mobile' %}
    {%- comment -%}
      MOXIE: drawer custom con tabs persistentes (Figma mobile). No reutiliza <header-drawer> nativo:
      su modelo de <details> anidados con drill-down no calza con tabs + panel por tab. El esqueleto
      exterior (details/summary hamburguesa con scroll-lock) sí replica al nativo para heredar el
      comportamiento del ícono en el header. Los mismos bloques hijos del desktop se re-presentan
      aquí vía CSS (src/styles/components/_header-drawer.scss) y assets/custom-header-drawer.js.
    {%- endcomment -%}
    <script
      src="{{ 'custom-header-drawer.js' | asset_url }}"
      type="module"
      fetchpriority="low"
    ></script>
    <div
      class="header__drawer"
      ref="headerDrawerContainer"
      data-hydration-key="custom-menu-drawer"
      {{ block.shopify_attributes }}
    >
      <custom-header-drawer class="custom-menu-drawer">
        <details
          id="Details-custom-menu-drawer"
          data-skip-node-update="true"
          class="custom-menu-drawer__container"
          ref="details"
          scroll-lock
        >
          <summary
            class="header__icon header__icon--menu header__icon--summary custom-menu-drawer__summary"
            aria-label="{{ 'accessibility.menu' | t }}"
            on:click="/toggle"
          >
            <span class="svg-wrapper custom-menu-drawer__icon custom-menu-drawer__icon--open">
              {{- 'icon-menu.svg' | inline_asset_content -}}
            </span>
            <span class="svg-wrapper custom-menu-drawer__icon custom-menu-drawer__icon--close">
              {{- 'icon-close.svg' | inline_asset_content -}}
            </span>
          </summary>
          <div ref="drawer" class="custom-menu-drawer__panel">
            <div class="custom-menu-drawer__search">
              {% render 'search', class: 'custom-menu-drawer__search-action', display_style: 'icon' %}
            </div>
            <nav
              class="custom-menu-drawer__nav"
              aria-label="{{ 'accessibility.header_navigation_label' | t }}"
              style="{% render 'menu-font-styles', settings: block_settings, menu_type: 'drawer' %} {% render 'submenu-font-styles', settings: block_settings %}"
            >
              <ul class="custom-menu-drawer__list list-unstyled" role="list">
                {{ children }}
              </ul>
            </nav>
          </div>
        </details>
      </custom-header-drawer>
    </div>

  {% else %}
    {% capture menu_items %}
      {{ children }}
      <li
        class="menu-list__list-item"
        role="presentation"
        slot="more"
        on:focus="/activate"
        on:blur="/deactivate"
        on:pointerenter="/activate"
        on:pointerleave="/deactivate"
      >
        <button role="listitem" class="menu-list__link button-unstyled">
          <span class="menu-list__link-title">{{ 'actions.more' | t }}</span>
        </button>
      </li>
    {% endcapture %}

    <header-menu
      ref="headerMenu"
      class="header-menu custom-menu"
      {{ block.shopify_attributes }}
      data-hydration-key="custom-menu-desktop"
    >
      <div class="header-menu__inner">
        {%- comment -%}
          MOXIE: los vars de submenu-font-styles van en el <nav> (no en cada submenu como el nativo)
          porque los paneles los emiten los bloques hijos, que no pueden leer los settings de este
          contenedor — las CSS custom properties cascadean hacia los paneles con el mismo efecto.
        {%- endcomment -%}
        <nav
          class="menu-list"
          aria-label="{{ 'accessibility.header_navigation_label' | t }}"
          style="{% render 'menu-font-styles', settings: block_settings, menu_type: 'mega_menu' %} {% render 'submenu-font-styles', settings: block_settings %}"
        >
          {% assign class = 'overflow-menu' | append: background_color_classes %}
          {% render 'overflow-list',
            class: class,
            ref: 'overflowMenu',
            children: menu_items,
            minimum-items: 2,
            data-testid: 'header-menu-overflow-list',
            attributes: 'data-skip-node-update'
          %}
        </nav>
      </div>

      <script
        src="{{ 'header-menu.js' | asset_url }}"
        type="module"
        fetchpriority="low"
      ></script>
    </header-menu>
{% endcase %}

{% style %}
  .header__underlay {
    --color-submenu: rgb({{ effective_submenu_color.rgb }});
  }
{% endstyle %}

{%- comment -%}
  MOXIE: CSS copiado 1:1 del {% stylesheet %} de blocks/_header-menu.liquid (nativo). Los
  {% stylesheet %} solo se incluyen en la página si el archivo que los contiene se renderiza —
  al reemplazar el block nativo, toda la maquinaria visual del mega menu (posicionamiento del
  submenu, animación clip-path, mostrar-en-hover con :has(), overflow "More") desaparecería.
  Se omitieron las reglas exclusivas de navigation_bar, del drawer nativo y de mega-menu-list
  (.mega-menu__link*, .mega-menu__column*, .mega-menu__content*) que este menú custom no usa.
  El drawer custom y los bloques de contenido se estilan en src/styles/components/.
{%- endcomment -%}
{% stylesheet %}
  .header__drawer {
    --header-drawer-min-height: 60px;
    display: flex;
    min-height: var(--header-drawer-min-height);
    align-items: center;
  }

  #header-component[data-menu-style='drawer'] .header__drawer {
    display: flex;
    min-height: var(--header-drawer-min-height);
  }

  @media screen and (min-width: 750px) {
    #header-component[data-menu-style='menu'] .header__drawer {
      display: none;
      min-height: 0;
    }
  }

  .header--compact .header__drawer {
    min-height: var(--minimum-touch-target);
  }

  .menu-list {
    --menu-horizontal-gap: var(--gap-xl);
    --menu-vertical-gap: var(--gap-xl);

    display: flex;
    height: 100%;
  }

  .menu-list__list {
    display: flex;
    justify-content: var(--grid-area-alignment);
  }

  .menu-list__list-item {
    flex-shrink: 0;
    white-space: nowrap;
    display: flex;
    align-items: center;
    height: 100%;
  }

  .menu-list__list-item[aria-hidden='true'] {
    visibility: hidden;
  }

  .menu-list__link {
    font-family: var(--menu-top-level-font-family);
    font-style: var(--menu-top-level-font-style);
    font-weight: var(--menu-top-level-font-weight);
    font-size: var(--menu-top-level-font-size);
    line-height: var(--menu-top-level-font-line-height);
    text-transform: var(--menu-top-level-font-case);
    color: var(--menu-top-level-font-color);
    text-decoration: none;
    display: flex;
    flex-direction: column;
    justify-content: center;
    cursor: pointer;
    height: 100%;
    margin-block: 0;

    &::after {
      content: '';
      position: absolute;
      display: none;
      top: var(--header-padding);
      height: var(--box-height);
      left: 0;
      right: 0;
    }

    &[data-safety-box='true']::after {
      display: block;
    }

    &:hover,
    &:focus {
      color: var(--menu-top-level-font-color);
    }

    @media screen and (min-width: 750px) {
      font-size: var(--menu-top-level-font-size-desktop);
    }
  }

  .menu-list__link-title {
    padding-inline: calc(var(--gap-xl) / 2);
  }
  [slot='overflow'] .menu-list__link-title {
    padding-inline: 0;
  }

  .menu-list__list-item:not([slot='overflow']) {
    flex-direction: column;
  }
  .menu-list__list-item:not([slot='overflow'])::after {
    content: '';
    width: 100%;
    height: var(--header-padding);
    margin-bottom: calc(-1 * var(--header-padding));
  }

  [slot='overflow'] > .menu-list__link::after {
    content: none;
  }

  .menu-list:where(:has(.menu-list__list-item:hover)),
  .menu-list:where(:has(.menu-list__list-item:focus-within)),
  .menu-list:where(:has(.menu-list__list-item:not([aria-hidden='true']) .menu-list__link--active)) {
    .menu-list__link {
      color: rgb(var(--menu-top-level-font-color-rgb) / var(--opacity-subdued-text));
    }
  }

  /* stylelint-disable-next-line selector-max-specificity */
  .menu-list:not(:has(.menu-list__list-item:hover)) .menu-list__link--active,
  .menu-list .menu-list__list-item:where(:hover, :focus-within) .menu-list__link,
  .menu-list .menu-list__list-item[slot='overflow'] .menu-list__link[aria-expanded='true'] {
    color: var(--menu-top-level-font-color);
  }

  .overflow-menu::part(list) {
    --focus-outline-size: calc(var(--focus-outline-offset) + var(--focus-outline-width));

    gap: 0;
    margin-inline: calc(-1 * var(--menu-horizontal-gap) / 2);
  }

  .overflow-menu {
    /* stylelint-disable-next-line declaration-no-important */
    background-color: transparent !important;
    padding: var(--focus-outline-size);
    margin: calc(-1 * var(--focus-outline-size));
  }

  /** mega menu **/
  .menu-list__submenu,
  .overflow-menu::part(overflow) {
    --submenu-padding-block-start: var(--padding-3xl);
    --submenu-padding-block-end: var(--padding-3xl);

    background-color: transparent;
  }

  .header__row[style*='--border-bottom-width: 0px'] {
    .menu-list__submenu.background-matches-parent,
    .overflow-menu.background-matches-parent::part(overflow) {
      --submenu-padding-block-start: 0px;
    }
  }

  .menu-list__list-item:where(:not([slot='overflow'])) > .menu-list__submenu,
  .overflow-menu::part(overflow) {
    --submenu-content-opacity: 0;
    --submenu-content-animation: opacity calc(var(--submenu-animation-speed) * 0.75) var(--animation-easing);

    visibility: hidden;
    position: absolute;
    width: 100%;
    left: 0;
    top: calc(100% - 1px + var(--border-bottom-width) - (var(--full-open-header-height) - var(--submenu-height)));
    z-index: var(--layer-header-menu);
    padding-inline: var(--padding-inline);
    /* Clip path starts at header height so it doesn't mess with the pointer events in the header */
    clip-path: rect(var(--header-height) 100% var(--full-open-header-height) 0); /* stylelint-disable-line */
    transition: clip-path var(--submenu-animation-speed) var(--ease-out-cubic); /* stylelint-disable-line */
  }

  [data-submenu-overlap-bottom-row] {
    .menu-list__list-item:where(:not([slot='overflow'])) > .menu-list__submenu,
    .overflow-menu::part(overflow) {
      clip-path: rect(var(--top-row-height) 100% var(--full-open-header-height) 0); /* stylelint-disable-line */
    }
  }

  /* Show the submenus on hover */
  .menu-list__list-item:has([aria-expanded='true']) > .menu-list__submenu,
  /* Show the overflow menu when a menu item is hovered */
  .overflow-menu:has([slot="overflow"] [aria-expanded='true'])::part(overflow-list),
  /* Keep the submenus open when they are hovered */
  .menu-list__submenu:is(:hover),
  .overflow-menu::part(overflow):hover {
    --submenu-content-opacity: 1;

    visibility: visible;
  }

  .overflow-menu::part(overflow) {
    --menu-top-level-font-size: var(--font-size--xlarge);

    display: grid;
    grid-template-columns: var(--full-page-grid-with-margins);
  }

  .overflow-menu::part(overflow-list) {
    position: relative;
    display: grid;
    grid-template-columns: minmax(auto, 200px) 1fr;
    grid-template-areas: 'left right';
    grid-template-rows: max-content;
    grid-gap: 0;
    grid-column: 2;
  }

  .menu-list__list-item:is([slot='overflow']) {
    --menu-top-level-font-color: var(--color-foreground);
    --menu-top-level-font-color-rgb: var(--color-foreground-rgb);

    display: contents;
    white-space: normal;

    .menu-list__link {
      grid-area: left;
      grid-row: auto;
      height: min-content;
      font-size: var(--font-size--xl);
      transition: var(--submenu-content-animation);
    }

    .menu-list__submenu {
      visibility: hidden;
      grid-row: 1;
      grid-area: right;
      grid-row-end: span calc(var(--overflow-count) + 1);
      padding-inline-start: var(--menu-horizontal-gap);
    }

    .menu-list__submenu-inner {
      transform: none;
      grid-column: unset;
      padding-block: 0;
    }

    .menu-list__link[aria-expanded='true'] + .menu-list__submenu {
      visibility: visible;
    }
  }

  .header-menu {
    height: 100%;
  }

  .menu-list__submenu-inner {
    position: relative;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
  }

  .menu-list__submenu-inner,
  .overflow-menu::part(overflow-list) {
    padding-block-start: var(--submenu-padding-block-start);
    padding-block-end: var(--submenu-padding-block-end);
    padding-inline: var(--section-padding-inline);
    opacity: var(--submenu-content-opacity);
    transition: var(--submenu-content-animation);
    transform: translateY(calc(var(--full-open-header-height) - var(--submenu-height)));

    /* Make overflow menu scrollable when content exceeds viewport */
    max-height: calc(80vh - var(--header-height));
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-width: thin;
    scrollbar-color: rgb(var(--color-foreground-rgb) / var(--opacity-40)) transparent;
  }

  .menu-list__list-item[slot='overflow'] .section {
    grid-template-columns: 1fr;
  }

  /* MOXIE: adaptado del nativo — la grilla custom reemplaza a .mega-menu__grid */
  .menu-list__list-item[slot='overflow'] .section .custom-menu-item__grid {
    grid-column: 1;
  }

  /* Estilos propios del menú custom Moxie (pill destacada + shell del drawer mobile) —
     migrados desde src/styles/components/_header-mega-menu.scss y _header-drawer.scss,
     ver docs/css-architecture.md. */
  #header-component {
    @media screen and (min-width: 750px) {
      /* El <li> es flex-direction: column (nativo), el eje principal es vertical: márgenes
         auto centran el pill dentro del alto completo del <li>. */
      &[data-menu-style='menu'] .custom-menu-item--highlight > .menu-list__link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-block: auto;
        gap: 10px;
        padding: 2px 6px;
        border-radius: 2px;
        max-height: 20px;
        background-color: var(--menu-highlight-background, #ffffff);
        color: var(--menu-highlight-text, #000000);
      }

      /* Pill con header sólido (Figma): fondo/texto fijos, no los de la config del bloque
         (que solo aplican sobre el overlay transparente). "Sólido" = header nunca
         transparente, o transparente que se volvió sólido por scroll. */
      &[data-menu-style='menu']:not([transparent]) .custom-menu-item--highlight > .menu-list__link,
      &[data-menu-style='menu'][transparent='not-sticky'][data-sticky-state='active']
        .custom-menu-item--highlight
        > .menu-list__link {
        background-color: #a3a3a3;
        color: #ffffff;
      }

      /* Tab activo (dropdown abierto) — Figma: bold + underline en el label. El pill (SALE)
         no lleva underline, cambia de color. */
      &[data-menu-style='menu']
        .custom-menu-item:not(.custom-menu-item--highlight)
        > .menu-list__link[aria-expanded='true']
        .menu-list__link-title {
        font-weight: 700;
        text-decoration: underline;
        text-underline-offset: 6px;
      }

      &[data-menu-style='menu'] .custom-menu-item--highlight > .menu-list__link[aria-expanded='true'] {
        background-color: #000000;
        color: #ffffff;
      }
    }
  }

  .custom-menu-drawer {
    display: flex;
    align-items: center;
  }

  /* MOXIE: `&__foo` (concatenación tipo Sass) no es válido en CSS nesting nativo — el
     nesting selector `&` solo puede seguirse de pseudo-clases/pseudo-elementos/atributos
     (`&:hover`, `&::after`, `&[attr]`), no de un identificador suelto. El navegador
     descarta la regla entera en silencio. Selectores completos, sin `&` BEM. */
  .custom-menu-drawer__summary {
    cursor: pointer;
    list-style: none;
  }

  .custom-menu-drawer__summary::-webkit-details-marker {
    display: none;
  }

  .custom-menu-drawer__icon svg {
    display: block;
    width: 20px;
    height: 20px;
  }

  .custom-menu-drawer__icon--close {
    display: none;
  }

  .custom-menu-drawer__container[open] .custom-menu-drawer__icon--open {
    display: none;
  }

  .custom-menu-drawer__container[open] .custom-menu-drawer__icon--close {
    display: block;
  }

  /* Panel principal del drawer: pantalla completa bajo el header, fondo blanco fijo (Figma)
     independiente del estado transparente del header. Colores hardcodeados a propósito
     hasta la pasada de estilos exactos. */
  .custom-menu-drawer__panel {
    --color-foreground: #141414;
    --color-foreground-rgb: 20 20 20;

    position: fixed;
    inset-inline: 0;
    /* #header-component nativo tiene `contain: layout style` (sections/header.liquid), lo que
       lo convierte en containing block de este `position: fixed` en vez del viewport. Con
       top+bottom la altura se calcularía contra los 60px del header, no del viewport,
       colapsando el panel a 0px. Altura explícita contra 100dvh evita eso. */
    top: var(--header-height, 60px);
    height: calc(100dvh - var(--header-height, 60px));
    z-index: var(--layer-header-menu, 3);
    display: flex;
    flex-direction: column;
    overflow-y: auto;
    background-color: #ffffff;
    color: var(--color-foreground);
    animation: custom-menu-drawer-in 0.25s var(--ease-out-cubic, ease-out);
  }

  /* Buscador como pill (mismo patrón del header desktop: botón nativo que abre #search-modal,
     vestido por CSS; el copy vive en CSS porque snippets/search.liquid no se toca). */
  .custom-menu-drawer__search {
    padding: 16px;

    .search-action {
      display: flex;
      width: 100%;
      align-items: center;
      justify-content: flex-start;
      gap: 8px;
      padding: 12px 16px;
      border-radius: 999px;
      background-color: rgb(var(--color-foreground-rgb) / 0.06);

      &::after {
        content: '¿Qué buscas hoy?';
        font-family: var(--font-body--family);
        font-size: 14px;
        color: rgb(var(--color-foreground-rgb) / 0.55);
        white-space: nowrap;
      }
    }
  }

  .custom-menu-drawer__nav {
    display: flex;
    flex-direction: column;
    flex: 1 0 auto;
  }

  /* Cada ítem aporta su tab (fila 1, vía order) y su panel (fila 2); los utility links van
     al final (footer). display:contents en .custom-menu-item + flex-wrap acá. */
  .custom-menu-drawer__list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    flex: 1 0 auto;
    align-content: flex-start;
    padding-inline: 16px;
  }

  @keyframes custom-menu-drawer-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .custom-menu-drawer__panel {
      animation: none;
    }
  }
{% endstylesheet %}

{%- comment -%} MOXIE: defaults de color literales — Shopify rechaza refs dinámicas a la paleta ({{ settings.color_palette.* }}) en schemas de block/section {%- endcomment -%}
{% schema %}
{
  "name": "Moxie Menú",
  "tag": null,
  "blocks": [
    {
      "type": "_custom_menu-item"
    },
    {
      "type": "_custom_menu-utility-link"
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Apariencia"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo del panel",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color de texto",
      "placeholder": "Predeterminado"
    },
    {
      "type": "header",
      "content": "Tipografía"
    },
    {
      "type": "select",
      "id": "type_font_primary_size",
      "label": "Tamaño del nivel principal",
      "options": [
        {
          "value": "0.625rem",
          "label": "10px"
        },
        {
          "value": "0.75rem",
          "label": "12px"
        },
        {
          "value": "0.875rem",
          "label": "14px"
        },
        {
          "value": "1rem",
          "label": "16px"
        },
        {
          "value": "1.125rem",
          "label": "18px"
        }
      ],
      "default": "0.75rem"
    },
    {
      "type": "select",
      "id": "menu_font_style",
      "label": "Tamaño del submenú",
      "options": [
        {
          "value": "regular",
          "label": "Pequeño"
        },
        {
          "value": "inverse",
          "label": "Mediano"
        },
        {
          "value": "inverse_large",
          "label": "Grande"
        }
      ],
      "default": "inverse"
    },
    {
      "type": "select",
      "id": "type_font_primary_link",
      "label": "Fuente",
      "options": [
        {
          "value": "body",
          "label": "Cuerpo"
        },
        {
          "value": "subheading",
          "label": "Subtítulo"
        },
        {
          "value": "heading",
          "label": "Título"
        },
        {
          "value": "accent",
          "label": "Acento"
        }
      ],
      "default": "body"
    },
    {
      "type": "select",

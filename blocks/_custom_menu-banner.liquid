{%- doc -%}
  Banner de imagen del mega menu custom Moxie (ej. "FASHION EDIT" / "días naf ... 50%dcto").

  Hijo de `_custom_menu-item` (Fase 2.5 — bloques anidados con guardrails).

  Wrapper delgado: todo el markup vive en snippets/custom-menu-banner.liquid.
{%- enddoc -%}

{% render 'custom-menu-banner',
  image: block.settings.image,
  heading: block.settings.heading,
  text: block.settings.text,
  cta_label: block.settings.cta_label,
  link: block.settings.link,
  content_position: block.settings.content_position,
  span_desktop: block.settings.span_desktop,
  block_attributes: block.shopify_attributes
%}

{% schema %}
{
  "name": "Moxie Banner de menú",
  "tag": null,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Texto"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texto del botón"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Enlace"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Posición del contenido",
      "options": [
        { "value": "bottom-left", "label": "Abajo izquierda" },
        { "value": "center", "label": "Centro" },
        { "value": "bottom-right", "label": "Abajo derecha" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "span_desktop",
      "label": "Ancho relativo en desktop",
      "info": "Peso relativo frente a los demás bloques del ítem.",
      "options": [
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "6", "label": "6" },
        { "value": "8", "label": "8" }
      ],
      "default": "4"
    }
  ]
}
{% endschema %}

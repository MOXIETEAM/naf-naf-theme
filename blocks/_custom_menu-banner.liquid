{%- doc -%}
  Banner de imagen del mega menu custom Moxie (ej. "FASHION EDIT" / "días naf ... 50%dcto").

  Hijo de `_custom_menu-item`. Imagen grande con texto overlay (heading + texto + CTA opcional).
  Si hay link, todo el banner es clickeable; el CTA es visual (patrón nativo de card con link).

  La imagen SIEMPRE lleva width/height explícitos: assets/header-menu.js mide offsetHeight del
  submenu para la animación de apertura.
{%- enddoc -%}

{% liquid
  assign banner_settings = block.settings
  if banner_settings.link != blank
    assign banner_tag = 'a'
  else
    assign banner_tag = 'div'
  endif
%}

<{{ banner_tag }}
  {% if banner_settings.link != blank %}
    href="{{ banner_settings.link }}"
  {% endif %}
  class="custom-menu-banner"
  style="--custom-menu-span: {{ banner_settings.span_desktop | default: 4 }};"
  {{ block.shopify_attributes }}
>
  <div class="custom-menu-banner__media">
    {%- if banner_settings.image != blank -%}
      {{
        banner_settings.image
        | image_url: width: 1000
        | image_tag: widths: '480, 640, 800, 1000', sizes: '(min-width: 990px) 30vw, 100vw', class: 'custom-menu-banner__image'
      }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'custom-menu-banner__image custom-menu-banner__image--placeholder' }}
    {%- endif -%}
  </div>
  {%- if banner_settings.heading != blank or banner_settings.text != blank or banner_settings.cta_label != blank -%}
    <div class="custom-menu-banner__content custom-menu-banner__content--{{ banner_settings.content_position }}">
      {%- if banner_settings.heading != blank -%}
        <p class="custom-menu-banner__heading">{{ banner_settings.heading }}</p>
      {%- endif -%}
      {%- if banner_settings.text != blank -%}
        <p class="custom-menu-banner__text">{{ banner_settings.text }}</p>
      {%- endif -%}
      {%- if banner_settings.cta_label != blank -%}
        <span class="custom-menu-banner__cta">
          {{ banner_settings.cta_label }}
          <span class="custom-menu-banner__cta-icon">{{ 'icon-chevron-right.svg' | inline_asset_content }}</span>
        </span>
      {%- endif -%}
    </div>
  {%- endif -%}
</{{ banner_tag }}>

{% schema %}
{
  "name": "Moxie Banner de menú",
  "tag": null,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Texto"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texto del botón"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Enlace"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Posición del contenido",
      "options": [
        {
          "value": "bottom-left",
          "label": "Abajo izquierda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "bottom-right",
          "label": "Abajo derecha"
        }
      ],
      "default": "bottom-left"
    },
    {
      "type": "select",
      "id": "span_desktop",
      "label": "Ancho en desktop",
      "options": [
        {
          "value": "3",
          "label": "1/4"
        },
        {
          "value": "4",
          "label": "1/3"
        },
        {
          "value": "6",
          "label": "1/2"
        },
        {
          "value": "8",
          "label": "2/3"
        }
      ],
      "default": "4"
    }
  ]
}
{% endschema %}

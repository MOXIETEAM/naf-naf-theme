{%- doc -%}
  Fila de tier del panel promocional Moxie (ej. MEMBER / SILVER / BLACK).

  Hijo de `_custom_menu-promo`. Ícono + nombre + descripción, con divisores entre filas (CSS).
{%- enddoc -%}

<div class="custom-menu-promo-tier" {{ block.shopify_attributes }}>
  {%- if block.settings.icon != blank -%}
    <span class="custom-menu-promo-tier__icon">
      {{ block.settings.icon | image_url: width: 48 | image_tag: widths: '24, 48', class: 'custom-menu-promo-tier__icon-image' }}
    </span>
  {%- endif -%}
  <span class="custom-menu-promo-tier__title">{{ block.settings.title }}</span>
  {%- if block.settings.text != blank -%}
    <span class="custom-menu-promo-tier__text">{{ block.settings.text }}</span>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Moxie Tier de membresía",
  "tag": null,
  "settings": [
    {
      "type": "image_picker",
      "id": "icon",
      "label": "Ícono"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Nombre",
      "default": "MEMBER"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Descripción",
      "default": "Tu entrada al programa."
    }
  ]
}
{% endschema %}

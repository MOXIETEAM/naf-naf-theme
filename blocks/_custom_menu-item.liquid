{%- doc -%}
  Ítem de nivel superior del menú custom Moxie (ROPA / COLECCIONES / NAF&ME / SALE).

  Hijo de `_custom_menu`. Emite el <li> con el contrato de markup que assets/header-menu.js
  espera (on:focus/blur/pointerenter/pointerleave, ref="menuitem", ref="submenu[]") para heredar
  gratis el hover-intent, la animación del dropdown y el overflow "More" del tema.

  Fase 3 — layouts rígidos: Figma solo define 4 layouts de dropdown posibles (ver
  docs/header-custom-todo.md). En vez de dejar que el cliente arme el contenido con bloques
  hijos libres (columna/card/card-group/banner/promo con span manual — Fase 2, reemplazada),
  el setting `menu_layout` elige uno de los 4 tipos fijos y solo expone los campos de contenido
  de ESE tipo (heading, link_list, imágenes, texto). La estructura (cuántas columnas/cards, en
  qué orden, con qué ancho) queda hardcodeada acá — el cliente no puede romperla.

  El mismo markup sirve para el dropdown desktop y el panel del tab en el drawer mobile — el
  contenedor de cada variante adapta layout/comportamiento vía CSS/JS.
{%- enddoc -%}

{% liquid
  assign s = block.settings
  assign panel_id = 'custom-menu-panel-' | append: block.id
%}

{% capture panel_content %}
  {% case s.menu_layout %}
    {% when 'grid' %}
      {% render 'custom-menu-column', heading: s.grid_col_1_heading, menu: s.grid_col_1_menu, bold_last_link: false, span_desktop: 1 %}
      {% render 'custom-menu-column', heading: s.grid_col_2_heading, menu: s.grid_col_2_menu, bold_last_link: true, span_desktop: 1 %}
      {% render 'custom-menu-column', heading: s.grid_col_3_heading, menu: s.grid_col_3_menu, bold_last_link: true, span_desktop: 1 %}
      {% render 'custom-menu-column', heading: s.grid_col_4_heading, menu: s.grid_col_4_menu, bold_last_link: true, span_desktop: 1 %}
      {% capture occasion_cards %}
        {% render 'custom-menu-card', image: s.grid_occasion_1_image, label: s.grid_occasion_1_label, link: s.grid_occasion_1_link %}
        {% render 'custom-menu-card', image: s.grid_occasion_2_image, label: s.grid_occasion_2_label, link: s.grid_occasion_2_link %}
        {% render 'custom-menu-card', image: s.grid_occasion_3_image, label: s.grid_occasion_3_label, link: s.grid_occasion_3_link %}
        {% render 'custom-menu-card', image: s.grid_occasion_4_image, label: s.grid_occasion_4_label, link: s.grid_occasion_4_link %}
      {% endcapture %}
      {% render 'custom-menu-card-group', heading: s.grid_occasions_heading, span_desktop: 8, content: occasion_cards %}

    {% when 'asymmetric' %}
      {% capture asymmetric_cards %}
        {% render 'custom-menu-card', image: s.asym_card_1_image, label: s.asym_card_1_label, link: s.asym_card_1_link %}
        {% render 'custom-menu-card', image: s.asym_card_2_image, label: s.asym_card_2_label, link: s.asym_card_2_link %}
        {% render 'custom-menu-card', image: s.asym_card_3_image, label: s.asym_card_3_label, link: s.asym_card_3_link %}
      {% endcapture %}
      {% render 'custom-menu-card-group', span_desktop: 6, content: asymmetric_cards %}
      {% render 'custom-menu-column', heading: s.asym_col_1_heading, menu: s.asym_col_1_menu, span_desktop: 2 %}
      {% render 'custom-menu-banner',
        image: s.asym_banner_image,
        heading: s.asym_banner_heading,
        link: s.asym_banner_link,
        content_position: 'bottom-left',
        span_desktop: 3
      %}
      {% render 'custom-menu-column', heading: s.asym_col_2_heading, menu: s.asym_col_2_menu, span_desktop: 1 %}

    {% when 'promo' %}
      {% capture promo_tiers %}
        {% render 'custom-menu-promo-tier', icon: s.promo_tier_1_icon, title: s.promo_tier_1_title, text: s.promo_tier_1_text %}
        {% render 'custom-menu-promo-tier', icon: s.promo_tier_2_icon, title: s.promo_tier_2_title, text: s.promo_tier_2_text %}
        {% render 'custom-menu-promo-tier', icon: s.promo_tier_3_icon, title: s.promo_tier_3_title, text: s.promo_tier_3_text %}
      {% endcapture %}
      {% render 'custom-menu-promo',
        image: s.promo_image,
        heading: s.promo_heading,
        subheading: s.promo_subheading,
        text: s.promo_text,
        cta_label: s.promo_cta_label,
        cta_link: s.promo_cta_link,
        span_desktop: 8,
        tiers_content: promo_tiers
      %}
      {% render 'custom-menu-banner',
        image: s.promo_banner_image,
        heading: s.promo_banner_heading,
        text: s.promo_banner_text,
        cta_label: s.promo_banner_cta_label,
        link: s.promo_banner_link,
        content_position: 'center',
        span_desktop: 4
      %}

    {% when 'sale' %}
      {% render 'custom-menu-column', heading: s.sale_col_1_heading, menu: s.sale_col_1_menu, bold_last_link: true, span_desktop: 1 %}
      {% render 'custom-menu-column', heading: s.sale_col_2_heading, menu: s.sale_col_2_menu, bold_last_link: true, span_desktop: 2 %}
      {% render 'custom-menu-column', heading: s.sale_col_3_heading, menu: s.sale_col_3_menu, bold_last_link: true, span_desktop: 1 %}
      {% capture sale_cards %}
        {% render 'custom-menu-card', image: s.sale_card_1_image, label: s.sale_card_1_label, link: s.sale_card_1_link %}
        {% render 'custom-menu-card', image: s.sale_card_2_image, label: s.sale_card_2_label, link: s.sale_card_2_link %}
        {% render 'custom-menu-card', image: s.sale_card_3_image, label: s.sale_card_3_label, link: s.sale_card_3_link %}
      {% endcapture %}
      {% render 'custom-menu-card-group', heading: s.sale_cards_heading, span_desktop: 5, content: sale_cards %}
      {% render 'custom-menu-banner',
        image: s.sale_banner_image,
        heading: s.sale_banner_heading,
        text: s.sale_banner_text,
        link: s.sale_banner_link,
        content_position: 'center',
        span_desktop: 3
      %}
  {% endcase %}
{% endcapture %}
{% assign panel_content = panel_content | strip %}

<li
  role="presentation"
  class="menu-list__list-item custom-menu-item{% if s.highlight %} custom-menu-item--highlight{% endif %}"
  on:focus="/activate"
  on:blur="/deactivate"
  on:pointerenter="/activate"
  on:pointerleave="/deactivate"
  {% if s.highlight %}
    style="--menu-highlight-background: {{ s.highlight_background_color }}; --menu-highlight-text: {{ s.highlight_text_color }};"
  {% endif %}
  {{ block.shopify_attributes }}
>
  <a
    href="{{ s.link | default: '#' }}"
    data-skip-node-update="true"
    class="menu-list__link custom-menu-item__link"
    {%- if panel_content != blank -%}
      aria-controls="{{ panel_id }}"
      aria-haspopup="true"
      aria-expanded="false"
    {%- endif -%}
    {%- if s.link == request.path -%}
      aria-current="page"
    {%- endif -%}
    ref="menuitem"
  >
    <span class="menu-list__link-title">{{ s.label }}</span>
  </a>
  {%- comment -%}
    MOXIE: tab del drawer mobile — oculto en desktop vía CSS. on:click resuelve contra el
    Component ancestro más cercano: en el drawer es <custom-header-drawer> (define selectTab).
  {%- endcomment -%}
  <button
    type="button"
    class="custom-menu-item__tab button-unstyled"
    on:click="/selectTab"
    aria-expanded="false"
    {% if panel_content != blank %}
      aria-controls="{{ panel_id }}"
    {% endif %}
  >
    {{ s.label }}
  </button>
  {%- if panel_content != blank -%}
    {%- comment -%}
      MOXIE: este id se duplica entre las dos copias (desktop/drawer) del static block. El JS del
      drawer (Hito 4) re-prefija los ids/aria de su subárbol al conectarse para restaurar unicidad.
    {%- endcomment -%}
    <div class="menu-list__submenu custom-menu-item__panel" ref="submenu[]">
      <div
        id="{{ panel_id }}"
        class="menu-list__submenu-inner"
      >
        <div class="mega-menu section section--full-width-margin section--{{ section.settings.section_width }}">
          <div class="custom-menu-item__grid">
            {{ panel_content }}
          </div>
        </div>
      </div>
    </div>
  {%- endif -%}
</li>

{% schema %}

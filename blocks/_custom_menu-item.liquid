{%- doc -%}
  Ítem de nivel superior del menú custom Moxie (ROPA / COLECCIONES / NAF&ME / SALE).

  Hijo de `_custom_menu`. Emite el <li> con el contrato de markup que assets/header-menu.js
  espera (on:focus/blur/pointerenter/pointerleave, ref="menuitem", ref="submenu[]") para heredar
  gratis el hover-intent, la animación del dropdown y el overflow "More" del tema.

  Fase 2.5 — bloques anidados con guardrails: el contenido del dropdown ya no es un `select` de
  4 layouts fijos con ~140 settings condicionados (Fase 3). Ahora son bloques hijos reales
  (`_custom_menu-column`, `_custom_menu-card-group`, `_custom_menu-banner`, `_custom_menu-promo`)
  que el merchant agrega, quita y reordena libremente desde el Theme Editor.

  MOXIE: Shopify no permite `limit`/`max_blocks` en el schema de un theme block (a diferencia de
  una section) — confirmado por Theme Check, que rechaza esas propiedades acá. El guardrail contra
  romper el layout no vive en el schema, vive en el CSS: el ancho de cada bloque hijo
  (`span_desktop`) es un peso relativo (flex-grow, ver `.custom-menu-item__grid` en
  `_header-mega-menu.scss`), no una fracción fija de 12 — cualquier cantidad/combinación (2
  columnas, solo cards, solo columnas, muchos bloques, etc.) se autodistribuye y envuelve a una
  fila nueva sin huecos ni desbordes.

  El mismo markup sirve para el dropdown desktop y el panel del tab en el drawer mobile — el
  contenedor de cada variante adapta layout/comportamiento vía CSS/JS.
{%- enddoc -%}

{% liquid
  assign s = block.settings
  assign panel_id = 'custom-menu-panel-' | append: block.id
%}

{% capture panel_content %}
  {% content_for 'blocks' %}
{% endcapture %}
{% assign panel_content = panel_content | strip %}

<li
  role="presentation"
  class="menu-list__list-item custom-menu-item{% if s.highlight %} custom-menu-item--highlight{% endif %}"
  on:focus="/activate"
  on:blur="/deactivate"
  on:pointerenter="/activate"
  on:pointerleave="/deactivate"
  {% if s.highlight %}
    style="--menu-highlight-background: {{ s.highlight_background_color }}; --menu-highlight-text: {{ s.highlight_text_color }};"
  {% endif %}
  {{ block.shopify_attributes }}
>
  <a
    href="{{ s.link | default: '#' }}"
    data-skip-node-update="true"
    class="menu-list__link custom-menu-item__link"
    {%- if panel_content != blank -%}
      aria-controls="{{ panel_id }}"
      aria-haspopup="true"
      aria-expanded="false"
    {%- endif -%}
    {%- if s.link == request.path -%}
      aria-current="page"
    {%- endif -%}
    ref="menuitem"
  >
    <span class="menu-list__link-title">{{ s.label }}</span>
  </a>
  {%- comment -%}
    MOXIE: tab del drawer mobile — oculto en desktop vía CSS. on:click resuelve contra el
    Component ancestro más cercano: en el drawer es <custom-header-drawer> (define selectTab).
  {%- endcomment -%}
  <button
    type="button"
    class="custom-menu-item__tab button-unstyled"
    on:click="/selectTab"
    aria-expanded="false"
    {% if panel_content != blank %}
      aria-controls="{{ panel_id }}"
    {% endif %}
  >
    {{ s.label }}
  </button>
  {%- if panel_content != blank -%}
    {%- comment -%}
      MOXIE: este id se duplica entre las dos copias (desktop/drawer) del static block. El JS del
      drawer (Hito 4) re-prefija los ids/aria de su subárbol al conectarse para restaurar unicidad.
    {%- endcomment -%}
    <div class="menu-list__submenu custom-menu-item__panel" ref="submenu[]">
      <div
        id="{{ panel_id }}"
        class="menu-list__submenu-inner"
      >
        <div class="mega-menu section section--full-width-margin section--{{ section.settings.section_width }}">
          <div class="custom-menu-item__grid">
            {{ panel_content }}
          </div>
        </div>
      </div>
    </div>
  {%- endif -%}
</li>

{% stylesheet %}
  /* Migrado desde src/styles/components/_header-mega-menu.scss y _header-drawer.scss,
     ver docs/css-architecture.md. */

  /* Tab del drawer: oculto por defecto (copia desktop); se muestra dentro del drawer. */
  .custom-menu-item__tab {
    display: none;
  }

  .custom-menu-drawer .custom-menu-item {
    display: contents;
  }

  /* El link de navegación desktop no participa en el drawer (los tabs lo reemplazan). */
  .custom-menu-drawer .custom-menu-item__link {
    display: none;
  }

  .custom-menu-drawer .custom-menu-item__tab {
    display: inline-flex;
    order: 1;
    align-items: center;
    padding: 12px 10px;
    font-family: var(--menu-top-level-font-family);
    font-size: 14px;
    text-transform: var(--menu-top-level-font-case);
    color: var(--color-foreground);
    border-block-end: 2px solid transparent;
  }

  .custom-menu-drawer .custom-menu-item[data-active] > .custom-menu-item__tab {
    border-block-end-color: currentColor;
    font-weight: 700;
  }

  /* Tab destacado (SALE) como pill invertida (Figma mobile). */
  .custom-menu-drawer .custom-menu-item--highlight > .custom-menu-item__tab {
    padding: 4px 10px;
    margin-inline-start: 6px;
    border-radius: 2px;
    border-block-end: none;
    background-color: #141414;
    color: #ffffff;
  }

  /* Panel del tab: anula la maquinaria del dropdown desktop (absolute + clip-path + visibility
     de blocks/_custom_menu.liquid) y lo muestra como bloque normal. */
  .custom-menu-drawer .custom-menu-item__panel {
    display: none;
    order: 2;
    width: 100%;

    /* El stylesheet nativo copiado en blocks/_custom_menu.liquid (dropdown desktop) define
       `.menu-list__submenu` con la MISMA especificidad (2 clases) que esta regla — el empate
       lo gana el que se inyecta más tarde en el <head>, que no es predecible entre un
       stylesheet de bloque y otro. Sin !important el panel del tab heredaba
       `position: absolute` + `clip-path` del desktop y quedaba literalmente fuera del
       viewport (bug encontrado en sesión de QA mobile). */
    position: static !important;
    clip-path: none !important;
    transition: none !important;
    visibility: visible;
  }

  .custom-menu-drawer .custom-menu-item[data-active] > .custom-menu-item__panel {
    display: block;
  }

  .custom-menu-drawer .menu-list__submenu-inner {
    opacity: 1;
    transform: none;
    padding: 0;
    max-height: none;
    overflow: visible;
    display: block;
  }

  /* El wrapper .section trae la grilla global de página; en el drawer es un bloque simple. */
  .custom-menu-drawer .custom-menu-item__panel .section {
    display: block;
    padding-inline: 0;
    margin: 0;
  }

  /* Grilla del panel del dropdown desktop (Fase 2.5 — bloques anidados con guardrails). Cada
     bloque hijo (columna/card-group/banner/promo) es un ítem flex cuyo peso
     (--custom-menu-span, setting "Ancho relativo en desktop" del bloque) reparte el espacio
     libre de forma RELATIVA, no como fracción fija de 12: con 2 columnas en vez de 4, las 2
     presentes se reparten el ancho sin dejar hueco; un ítem "full imágenes" o "full columnas"
     también se autodistribuye sin configuración especial. flex-wrap + min-width por tipo (ver
     reglas de cada bloque) es la válvula de seguridad: si la suma de min-widths no cabe en una
     fila, envuelve a la siguiente en vez de aplastar el contenido. */
  .custom-menu-item__grid {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(22px, 2.22vw, 32px) clamp(17px, 1.67vw, 24px);
    align-items: start;
    padding-block: clamp(19px, 1.94vw, 28px) clamp(28px, 2.78vw, 40px);

    > * {
      flex: var(--custom-menu-span, 3) 1 0;
    }
  }

  /* Contenido del tab en una columna: cards/grupos primero, banner/promo después, columnas
     (filas drill-down) al final — orden del Figma mobile. */
  .custom-menu-drawer .custom-menu-item__grid {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding-block: 8px 24px;

    > .custom-menu-card,
    > .custom-menu-card-group {
      order: 1;
    }

    > .custom-menu-banner,
    > .custom-menu-promo {
      order: 2;
    }

    > .custom-menu-column {
      order: 3;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Moxie Ítem de menú",
  "tag": null,
  "blocks": [
    {
      "type": "_custom_menu-column"
    },
    {
      "type": "_custom_menu-card-group"
    },
    {
      "type": "_custom_menu-banner"
    },
    {
      "type": "_custom_menu-promo"
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Etiqueta",
      "default": "Ítem"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Enlace"
    },
    {
      "type": "paragraph",
      "content": "El contenido del dropdown se arma agregando bloques hijos abajo (columna de links, grupo de cards, banner, panel promocional) — se pueden agregar, quitar y reordenar libremente, dentro de los límites de cada tipo."
    },
    {
      "type": "header",
      "content": "Ítem destacado"
    },
    {
      "type": "checkbox",
      "id": "highlight",
      "label": "Resaltar como pill",
      "default": false,
      "info": "Muestra el ítem como una píldora de color (ej. SALE)."
    },
    {
      "type": "color",
      "id": "highlight_background_color",
      "label": "Color de fondo",
      "default": "#ffffff",
      "visible_if": "{{ block.settings.highlight }}"
    },
    {
      "type": "color",
      "id": "highlight_text_color",
      "label": "Color de texto",
      "default": "#000000",
      "visible_if": "{{ block.settings.highlight }}"
    }
  ]
}
{% endschema %}

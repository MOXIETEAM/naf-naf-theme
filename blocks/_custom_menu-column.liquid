{%- doc -%}
  Columna de links del mega menu custom Moxie (ej. TRENDING / PRENDAS / DENIM).

  Hijo de `_custom_menu-item`. Los links vienen de un menú de Admin → Navegación (link_list),
  decisión confirmada: edición bulk familiar y estructura de 2 niveles gratis.

  Doble renderizado con el mismo markup:
  - Desktop: título + lista de links visible en la grilla del dropdown.
  - Drawer mobile: fila con chevron (drill-down) que abre el panel con los links a pantalla
    completa con botón "back" — CSS/JS del drawer adaptan, este bloque no sabe de variantes.
{%- enddoc -%}

{% liquid
  assign col_settings = block.settings
  assign menu = col_settings.menu
%}

<div
  class="custom-menu-column{% if col_settings.bold_last_link %} custom-menu-column--bold-last{% endif %}"
  style="--custom-menu-span: {{ col_settings.span_desktop | default: 1 }};"
  {{ block.shopify_attributes }}
>
  {%- if col_settings.heading != blank -%}
    <p class="custom-menu-column__heading">{{ col_settings.heading }}</p>
  {%- endif -%}

  <button
    type="button"
    class="custom-menu-column__drill-row button-unstyled"
    on:click="/drillDown"
  >
    <span>{{ col_settings.heading | default: menu.title }}</span>
    <span class="custom-menu-column__drill-icon">{{ 'icon-chevron-right.svg' | inline_asset_content }}</span>
  </button>

  <div class="custom-menu-column__panel" data-drill-panel>
    <button
      type="button"
      class="custom-menu-column__back button-unstyled"
      on:click="/drillBack"
    >
      <span class="custom-menu-column__back-icon">{{ 'icon-chevron-left.svg' | inline_asset_content }}</span>
      <span>{{ col_settings.heading | default: menu.title }}</span>
    </button>

    <ul class="custom-menu-column__list list-unstyled">
      {%- if menu.links.size > 0 -%}
        {%- for link in menu.links -%}
          <li class="custom-menu-column__list-item">
            <a
              href="{{ link.url }}"
              class="custom-menu-column__link"
              {% if link.current %}
                aria-current="page"
              {% endif %}
            >
              {{- link.title -}}
            </a>
          </li>
        {%- endfor -%}
      {%- elsif request.design_mode -%}
        {%- comment -%} Placeholders solo en el editor: el layout es visible sin menú asignado; en producción no se renderiza nada. {%- endcomment -%}
        {%- for i in (1..4) -%}
          <li class="custom-menu-column__list-item">
            <span class="custom-menu-column__link custom-menu-column__link--placeholder">Enlace {{ i }}</span>
          </li>
        {%- endfor -%}
      {%- endif -%}
    </ul>
  </div>
</div>

{% schema %}
{
  "name": "Moxie Columna de links",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Categoría",
      "info": "En mobile es el texto de la fila que abre el listado."
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menú",
      "info": "Crea un menú en Admin → Contenido → Menús con los enlaces de esta columna."
    },
    {
      "type": "checkbox",
      "id": "bold_last_link",
      "label": "Resaltar último enlace",
      "default": false,
      "info": "Ej. \"Ver todo\" en negrita al final de la lista."
    },
    {
      "type": "select",
      "id": "span_desktop",
      "label": "Ancho en desktop",
      "options": [
        {
          "value": "1",
          "label": "1/12"
        },
        {
          "value": "2",
          "label": "1/6"
        },
        {
          "value": "3",
          "label": "1/4"
        },
        {
          "value": "4",
          "label": "1/3"
        },
        {
          "value": "6",
          "label": "1/2"
        },
        {
          "value": "8",
          "label": "2/3"
        },
        {
          "value": "12",
          "label": "Completo"
        }
      ],
      "default": "2"
    }
  ]
}
{% endschema %}

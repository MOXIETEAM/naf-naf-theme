{%- doc -%}
  Columna de links del mega menu custom Moxie (ej. TRENDING / PRENDAS / DENIM).

  Hijo de `_custom_menu-item` (Fase 2.5 — bloques anidados con guardrails). El merchant agrega,
  quita y reordena estos bloques libremente dentro de los límites del schema (`limit` en el
  bloque padre). El ancho (`span_desktop`) es un peso relativo (flex-grow), no una fracción fija
  de 12 — con menos columnas, las presentes se reparten el espacio libre automáticamente.

  Wrapper delgado: todo el markup vive en snippets/custom-menu-column.liquid (reutilizado tal
  cual desde Fase 3, agnóstico a si lo llama un `{% case %}` fijo o un bloque real).
{%- enddoc -%}

{% render 'custom-menu-column',
  heading: block.settings.heading,
  menu: block.settings.menu,
  bold_last_link: block.settings.bold_last_link,
  span_desktop: block.settings.span_desktop,
  block_attributes: block.shopify_attributes
%}

{% schema %}
{
  "name": "Moxie Columna de menú",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Columna"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menú",
      "info": "Menú de Admin → Navegación con los enlaces de esta columna."
    },
    {
      "type": "checkbox",
      "id": "bold_last_link",
      "label": "Resaltar último enlace en negrita",
      "default": false,
      "info": "Útil para un enlace final tipo \"Ver todo\"."
    },
    {
      "type": "select",
      "id": "span_desktop",
      "label": "Ancho relativo en desktop",
      "info": "Peso relativo frente a los demás bloques del ítem — no hace falta que la suma dé un número exacto, el espacio libre se reparte solo.",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "6", "label": "6" },
        { "value": "8", "label": "8" },
        { "value": "12", "label": "12" }
      ],
      "default": "1"
    }
  ]
}
{% endschema %}

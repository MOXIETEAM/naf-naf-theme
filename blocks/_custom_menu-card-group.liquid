{%- doc -%}
  Grupo de cards del mega menu custom Moxie (ej. "POR OCASIONES DE USO" / "EXPLORA TUS FAVORITOS").

  Hijo de `_custom_menu-item`; sus hijos son `_custom_menu-card`. En desktop: título + fila de
  cards en sub-grilla uniforme. En el drawer mobile: los cards pasan a scroll horizontal (CSS).
{%- enddoc -%}

<div
  class="custom-menu-card-group"
  style="--custom-menu-span: {{ block.settings.span_desktop | default: 8 }};"
  {{ block.shopify_attributes }}
>
  {%- if block.settings.heading != blank -%}
    <p class="custom-menu-card-group__heading">{{ block.settings.heading }}</p>
  {%- endif -%}
  <div class="custom-menu-card-group__cards">
    {% content_for 'blocks' %}
  </div>
</div>

{% schema %}
{
  "name": "Moxie Grupo de cards",
  "tag": null,
  "blocks": [
    {
      "type": "_custom_menu-card"
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Grupo de cards"
    },
    {
      "type": "select",
      "id": "span_desktop",
      "label": "Ancho en desktop",
      "options": [
        {
          "value": "4",
          "label": "1/3"
        },
        {
          "value": "6",
          "label": "1/2"
        },
        {
          "value": "8",
          "label": "2/3"
        },
        {
          "value": "12",
          "label": "Completo"
        }
      ],
      "default": "8"
    }
  ]
}
{% endschema %}

{%- doc -%}
  Card de imagen del mega menu custom Moxie (ej. DAILYWEAR / DREAMY / TEJIDOS).

  Hijo de `_custom_menu-item` o de `_custom_menu-card-group`. Imagen con label debajo y link.
  En el drawer mobile los cards de un grupo van en scroll horizontal (lo maneja el CSS del grupo).

  La imagen SIEMPRE lleva width/height explícitos: assets/header-menu.js mide offsetHeight del
  submenu para la animación de apertura — una imagen sin dimensiones rompería la medición.
{%- enddoc -%}

{% liquid
  assign card_settings = block.settings
  if card_settings.link != blank
    assign card_tag = 'a'
  else
    assign card_tag = 'div'
  endif
%}

<{{ card_tag }}
  {% if card_settings.link != blank %}
    href="{{ card_settings.link }}"
  {% endif %}
  class="custom-menu-card"
  style="--custom-menu-span: {{ card_settings.span_desktop | default: 3 }};"
  {{ block.shopify_attributes }}
>
  <div class="custom-menu-card__media">
    {%- if card_settings.image != blank -%}
      {{
        card_settings.image
        | image_url: width: 800
        | image_tag: widths: '320, 480, 640, 800', sizes: '(min-width: 990px) 20vw, 60vw', class: 'custom-menu-card__image'
      }}
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag: 'custom-menu-card__image custom-menu-card__image--placeholder' }}
    {%- endif -%}
  </div>
  {%- if card_settings.label != blank -%}
    <span class="custom-menu-card__label">{{ card_settings.label }}</span>
  {%- endif -%}
</{{ card_tag }}>

{% schema %}
{
  "name": "Moxie Card de imagen",
  "tag": null,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Etiqueta",
      "default": "Card"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Enlace"
    },
    {
      "type": "select",
      "id": "span_desktop",
      "label": "Ancho en desktop",
      "options": [
        {
          "value": "2",
          "label": "1/6"
        },
        {
          "value": "3",
          "label": "1/4"
        },
        {
          "value": "4",
          "label": "1/3"
        },
        {
          "value": "6",
          "label": "1/2"
        }
      ],
      "default": "3"
    }
  ]
}
{% endschema %}

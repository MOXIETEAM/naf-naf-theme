{%- doc -%}
  MOXIE: desktop wishlist toggle for the product card, placed via block_order next to the title/price.
  The mobile instance is rendered separately, absolutely positioned over the gallery image
  (see blocks/_product-card-gallery.liquid), and hidden on desktop via CSS.
{%- enddoc -%}

{% liquid
  assign product = closest.product
%}

{% unless product == blank %}
  {% render 'custom_wishlist-button', product: product, variant: 'desktop' %}
{% endunless %}

{% stylesheet %}
  /* MOXIE: en Figma el corazón va en la misma fila que el precio, alineado a la
     derecha (no flotando sobre la imagen como en mobile). Se ancla al borde
     inferior/derecho de la card — como price es el último bloque en flujo antes
     de este, coincide con la línea del precio. Ver padding-inline-end del bloque
     price en el template para dejarle espacio al ícono. */
  .product-card__content {
    position: relative;
  }

  .wishlist-button--desktop {
    position: absolute;
    inset-block-end: 0;
    inset-inline-end: 0;
  }

  /* MOXIE: un nombre de producto largo wrappeaba libre a 2-3 líneas (sin límite
     nativo) y con el gap de 4px del card, su última línea invadía el ícono de
     44px de touch target de arriba. Se trunca a 1 línea + ellipsis y se le
     reserva el mismo padding-inline-end que ya usa price, para que título y
     wishlist siempre tengan su propio espacio. */
  @media screen and (min-width: 750px) {
    .product-card__content [role="heading"] {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      padding-inline-end: 32px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Moxie Wishlist",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "Botón de favoritos (solo desktop). La versión mobile ya viene incluida dentro de la imagen de la card."
    }
  ],
  "presets": [
    {
      "name": "Moxie Wishlist",
      "category": "Moxie"
    }
  ]
}
{% endschema %}

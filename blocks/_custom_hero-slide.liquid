{% comment %}
  MOXIE: custom slide block — extends the native `_slide.liquid` pattern with independent
  desktop/mobile media (image or video), copying the art-direction approach from `sections/hero.liquid`.
  Wrapper markup renders for the `hero-fade-slider` custom element (crossfade, no slideshow-slide
  scroll/translate) instead of the native `slideshow-slide` snippet.
  Used exclusively by `sections/custom_hero-slider.liquid`.
{% endcomment %}
{% assign block_settings = block.settings %}
{%- assign block_index = section.blocks | find_index: 'id', block.id -%}
{%- assign section_index = section.index -%}

{% capture children %}
  {% liquid
    assign media_1 = 'none'
    assign media_1_mobile = 'none'
    assign media_count_mobile = 0

    if block_settings.image_1 != blank and block_settings.media_type_1 == 'image'
      assign media_1 = 'image'
    endif
    if block_settings.video_1 != blank and block_settings.media_type_1 == 'video'
      assign media_1 = 'video'
    endif

    if block_settings.custom_mobile_media
      if block_settings.image_1_mobile != blank and block_settings.media_type_1_mobile == 'image'
        assign media_1_mobile = 'image'
        assign media_count_mobile = 1
      endif
      if block_settings.video_1_mobile != blank and block_settings.media_type_1_mobile == 'video'
        assign media_1_mobile = 'video'
        assign media_count_mobile = 1
      endif
    endif

    assign fallback_to_desktop = false
    if block_settings.custom_mobile_media == false or media_count_mobile == 0
      assign media_1_mobile = media_1
      assign fallback_to_desktop = true
    endif

    assign media_wrapper_desktop_class = 'slide__media-wrapper slide__media-wrapper--desktop'
    assign media_wrapper_mobile_class = 'slide__media-wrapper slide__media-wrapper--mobile'
    if fallback_to_desktop
      assign media_wrapper_desktop_class = media_wrapper_desktop_class | append: ' slide__media-wrapper--mobile'
    endif

    assign preview_image = block_settings.image_1
    if media_1 == 'video'
      assign preview_image = block_settings.video_1.preview_image
    endif

    assign rounded_image_corners = false
    if block_settings.background_color == blank or section.settings.background_color == block_settings.background_color
      assign rounded_image_corners = true
    endif

    if block_settings.background_color != blank
      render 'contrast-override', background_color: block_settings.background_color, section_id: block.id, skip_contrast: true
      assign class = 'color-custom-' | append: block.id
    endif
  %}
  <div class="slide__image-container{% if rounded_image_corners %} slide__image-container--rounded{% endif %}">
    {%- if block_settings.toggle_overlay -%}
      {% render 'overlay', settings: block_settings %}
    {%- endif -%}
    {%- if preview_image -%}
      {%- liquid
        assign height = preview_image.width | divided_by: preview_image.aspect_ratio | round
        assign sizes = '100vw'
        assign sizes_mobile = '100vw'
        assign lazy_sizes = 'auto, ' | append: sizes
        assign widths = '832, 1200, 1600, 1920, 2560, 3840'
        assign mobile_widths = '416, 600, 800, 1200, 1600'
        assign mobile_widths_array = mobile_widths | split: ', '
      %}

      {%- liquid
        assign loading = 'lazy'

        if block_index == 0 and section_index <= 3
          assign loading = 'eager'
          assign sizes = lazy_sizes
        endif

        assign fetchpriority = 'low'
        if block_index == 0 and section_index == 1
          assign fetchpriority = 'high'
        endif
      -%}

      {%- if media_1 == 'image' and media_1_mobile == 'image' and fallback_to_desktop == false -%}
        {%- comment -%} Both desktop and mobile are images: art direction via picture element. {%- endcomment -%}
        <picture class="slide__image-picture">
          <source
            media="(max-width: 749px)"
            srcset="
              {%- for mobile_width in mobile_widths_array -%}
                {{ block_settings.image_1_mobile | image_url: width: mobile_width }} {{ mobile_width }}w{% unless forloop.last %},{% endunless %}
              {%- endfor -%}
            "
            sizes="{{ sizes_mobile }}"
            width="{{ block_settings.image_1_mobile.width }}"
            height="{{ block_settings.image_1_mobile.height }}"
          >
          {{
            block_settings.image_1
            | image_url: width: 3840
            | image_tag: height: height, sizes: sizes, widths: widths, class: 'slide__image', loading: loading, fetchpriority: fetchpriority
          }}
        </picture>
      {%- else -%}
        {%- if media_1 == 'image' -%}
          <div class="{{ media_wrapper_desktop_class }}">
            {{
              block_settings.image_1
              | image_url: width: 3840
              | image_tag: height: height, sizes: sizes, widths: widths, class: 'slide__image', loading: loading, fetchpriority: fetchpriority
            }}
          </div>
        {%- elsif media_1 == 'video' -%}
          <div class="{{ media_wrapper_desktop_class }}">
            {%- if block_settings.video_1.preview_image -%}
              {{
                block_settings.video_1.preview_image
                | image_url: width: 3840
                | image_tag:
                  height: height,
                  sizes: sizes,
                  widths: widths,
                  loading: loading,
                  class: 'slide__video-poster',
                  fetchpriority: fetchpriority
              }}
            {%- endif -%}
            {{
              block_settings.video_1
              | video_tag: poster: nil, autoplay: true, loop: true, controls: false, muted: true, class: 'slide__video'
            }}
          </div>
        {%- endif -%}

        {%- unless fallback_to_desktop -%}
          {%- if media_1_mobile == 'image' -%}
            <div class="{{ media_wrapper_mobile_class }}">
              {{
                block_settings.image_1_mobile
                | image_url: width: 1600
                | image_tag:
                  width: block_settings.image_1_mobile.width,
                  widths: mobile_widths,
                  height: block_settings.image_1_mobile.height,
                  alt: block_settings.image_1_mobile.alt,
                  class: 'slide__image',
                  sizes: sizes_mobile,
                  loading: loading,
                  fetchpriority: fetchpriority
              }}
            </div>
          {%- elsif media_1_mobile == 'video' -%}
            <div class="{{ media_wrapper_mobile_class }}">
              {%- if block_settings.video_1_mobile.preview_image -%}
                {{
                  block_settings.video_1_mobile.preview_image
                  | image_url: width: 1600
                  | image_tag: loading: loading, class: 'slide__video-poster', fetchpriority: fetchpriority
                }}
              {%- endif -%}
              {{
                block_settings.video_1_mobile
                | video_tag: poster: nil, autoplay: true, loop: true, controls: false, muted: true, class: 'slide__video'
              }}
            </div>
          {%- endif -%}
        {%- endunless -%}
      {%- endif -%}
    {%- else -%}
      {%- liquid
        assign modulo_result = block_index | modulo: 2
        assign placeholder_variant = 2 | minus: modulo_result
        assign placeholder_name = 'hero-apparel-' | append: placeholder_variant
      -%}
      {{ placeholder_name | placeholder_svg_tag: 'slide__image' }}
    {%- endif -%}
  </div>
  <div
    class="spacing-style slide__content {{ class }}{% if preview_image or block_settings.toggle_overlay %} background-transparent{% endif %}"
    style="{% render 'spacing-style', settings: block_settings %}"
  >
    <div
      class="group-block-content
      layout-panel-flex
      layout-panel-flex--{{ block_settings.content_direction }}
      {% if block_settings.vertical_on_mobile %}mobile-column{% endif %}"
      style="{% render 'layout-panel-style', settings: block_settings %}"
    >
      {% content_for 'blocks' %}
    </div>
  </div>
{% endcapture %}

{% liquid
  assign peek_src = ''
  if preview_image != blank
    assign peek_src = preview_image | image_url: width: 400
  endif
%}

<div
  class="hero-fade-slide{% if block_index == 0 %} is-active{% endif %}{% if class %} {{ class }}{% endif %}"
  ref="slides[]"
  aria-hidden="{% if block_index == 0 %}false{% else %}true{% endif %}"
  {% if peek_src != blank %}
    data-peek-src="{{ peek_src }}"
  {% endif %}
  {{ block.shopify_attributes }}
>
  {{ children }}
</div>

{% stylesheet %}
  .slide__content {
    height: 100%;
    position: relative;
    z-index: var(--layer-flat);
  }

  /*
   * MOXIE: los stylesheets de componentes de Horizon se bundlean globalmente, y
   * `_slide.liquid` (nativo) define `.slide__content { opacity: 0; animation: slide-reveal... }`
   * atado a un `--slideshow-timeline` que aquí no corre (no usamos slideshow-component).
   * Se sube la especificidad para ganarle siempre a esa regla, sin tocar el archivo nativo.
   */
  .hero-fade-slide .slide__content {
    opacity: 1;
    animation: none;
  }

  .slide__content > * {
    margin: auto;
  }

  .slide__content.background-transparent {
    background-color: transparent;
  }

  .hero-fade-slide > .slide__image-container {
    display: flex;
    width: 100%;
    height: 100%;
    overflow: hidden;
    position: absolute;
  }

  .slide__image-container > .slide__image,
  .slide__image-container > .slide__video,
  .slide__image-container > .slide__video-poster {
    position: relative;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
  }

  .slide__image-container > .slide__video-poster {
    position: absolute;
  }

  .slide__image-picture {
    display: contents;
  }

  .slide__media-wrapper {
    display: block;
    width: 100%;
    height: 100%;
  }

  .slide__media-wrapper > .slide__image,
  .slide__media-wrapper > .slide__video,
  .slide__media-wrapper > .slide__video-poster {
    position: relative;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
  }

  .slide__media-wrapper > .slide__video-poster {
    position: absolute;
  }

  /* Mobile/Desktop media visibility */
  .slide__media-wrapper--mobile {
    display: none;
  }

  .slide__media-wrapper--desktop {
    display: block;
  }

  @media screen and (max-width: 749px) {
    .slide__media-wrapper--desktop {
      display: none;
    }

    .slide__media-wrapper--mobile {
      display: block;
    }
  }

  .hero-fade-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    z-index: 0;
    transition: opacity 600ms ease, visibility 0s 600ms;
  }

  .hero-fade-slide.is-active {
    opacity: 1;
    visibility: visible;
    z-index: 1;
    transition: opacity 600ms ease;
  }

  @media (prefers-reduced-motion) {
    .hero-fade-slide {
      transition: none;
    }
  }

  .hero-fade-slide .slide__image-container--rounded {
    border-radius: var(--corner-radius, 0);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Moxie Hero Slide",
  "tag": null,
  "blocks": [
    {
      "type": "_heading"
    },
    {
      "type": "button"
    },
    {
      "type": "text"
    },
    {
      "type": "group"
    },
    {
      "type": "image"
    },
    {
      "type": "video"
    },
    {
      "type": "icon"
    },
    {
      "type": "jumbo-text"
    },
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    }
  ],
  "settings": [
    {
      "type": "select",
      "id": "media_type_1",
      "label": "t:settings.type",
      "options": [
        {
          "value": "image",
          "label": "t:options.image"
        },
        {
          "value": "video",
          "label": "t:options.video"
        }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "t:settings.image",
      "visible_if": "{{ block.settings.media_type_1 == 'image' }}"
    },
    {
      "type": "video",
      "id": "video_1",
      "label": "t:settings.video",
      "visible_if": "{{ block.settings.media_type_1 == 'video' }}"
    },
    {
      "type": "header",
      "content": "t:content.mobile_media"
    },
    {
      "type": "checkbox",
      "id": "custom_mobile_media",
      "label": "t:settings.custom_mobile_media",
      "default": false
    },
    {
      "type": "select",
      "id": "media_type_1_mobile",
      "label": "t:settings.type",
      "options": [
        {
          "value": "image",
          "label": "t:options.image"
        },
        {
          "value": "video",
          "label": "t:options.video"
        }
      ],
      "default": "image",
      "visible_if": "{{ block.settings.custom_mobile_media }}"
    },
    {
      "type": "image_picker",
      "id": "image_1_mobile",
      "label": "t:settings.image",
      "visible_if": "{{ block.settings.custom_mobile_media and block.settings.media_type_1_mobile == 'image' }}"
    },
    {
      "type": "video",
      "id": "video_1_mobile",
      "label": "t:settings.video",
      "visible_if": "{{ block.settings.custom_mobile_media and block.settings.media_type_1_mobile == 'video' }}"
    },
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "select",
      "id": "content_direction",
      "label": "t:settings.direction",
      "options": [
        {
          "value": "column",
          "label": "t:options.vertical"
        },
        {
          "value": "row",
          "label": "t:options.horizontal"
        }
      ],
      "default": "column"
    },
    {
      "type": "checkbox",
      "id": "vertical_on_mobile",
      "label": "t:settings.vertical_on_mobile",
      "default": true,
      "visible_if": "{{ block.settings.content_direction == 'row' }}"
    },
    {
      "type": "select",
      "id": "horizontal_alignment",
      "label": "t:settings.alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.left"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.right"
        },
        {
          "value": "space-between",
          "label": "t:options.space_between"
        }
      ],
      "default": "flex-start",
      "visible_if": "{{ block.settings.content_direction == 'row' }}"
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "t:settings.position",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.top"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.bottom"
        }
      ],
      "default": "center",
      "visible_if": "{{ block.settings.content_direction == 'row' }}"
    },
    {
      "type": "checkbox",
      "id": "align_baseline",
      "label": "t:settings.align_baseline",
      "default": false,
      "visible_if": "{{ block.settings.vertical_alignment == 'flex-end' }}"
    },
    {
      "type": "select",
      "id": "horizontal_alignment_flex_direction_column",
      "label": "t:settings.alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.left"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.right"
        }
      ],
      "default": "flex-start",
      "visible_if": "{{ block.settings.content_direction != 'row' }}"
    },
    {
      "type": "select",
      "id": "vertical_alignment_flex_direction_column",
      "label": "t:settings.position",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.top"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.bottom"
        },
        {
          "value": "space-between",
          "label": "t:options.space_between"
        }
      ],
      "default": "center",
      "visible_if": "{{ block.settings.content_direction == 'column' }}"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:settings.background_color",
      "placeholder": "t:settings.default"
    },
    {
      "type": "checkbox",
      "id": "toggle_overlay",
      "label": "t:settings.media_overlay"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "t:settings.overlay_color",
      "alpha": true,
      "default": "#00000026",
      "visible_if": "{{ block.settings.toggle_overlay }}"
    },
    {
      "type": "select",
      "id": "overlay_style",
      "label": "t:settings.overlay_style",
      "options": [
        {
          "value": "solid",
          "label": "t:options.solid"
        },
        {
          "value": "gradient",
          "label": "t:options.gradient"
        }
      ],
      "default": "solid",
      "visible_if": "{{ block.settings.toggle_overlay }}"
    },
    {
      "type": "select",
      "id": "gradient_direction",
      "label": "t:settings.gradient_direction",
      "options": [
        {
          "value": "to top",
          "label": "t:options.up"
        },
        {
          "value": "to bottom",
          "label": "t:options.down"
        }
      ],
      "default": "to top",
      "visible_if": "{{ block.settings.toggle_overlay and block.settings.overlay_style == 'gradient' }}"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Moxie Hero Slide",
      "settings": {
        "horizontal_alignment_flex_direction_column": "flex-start",
        "vertical_alignment_flex_direction_column": "flex-end",
        "padding-inline-start": 48,
        "padding-inline-end": 48,
        "padding-block-start": 48,
        "padding-block-end": 64
      },
      "blocks": {
        "eyebrow": {
          "type": "text",
          "name": "Eyebrow",
          "settings": {
            "text": "<p>NEW DROP</p>",
            "type_preset": "custom",
            "font_size": "0.875rem",
            "case": "uppercase",
            "letter_spacing": "loose",
            "padding-block-end": 8
          }
        },
        "heading": {
          "type": "text",
          "name": "t:names.heading",
          "settings": {
            "text": "<h2>Love is where mom is</h2>",
            "padding-block-end": 20
          }
        },
        "button": {
          "type": "button",
          "settings": {
            "label": "Comprar ahora",
            "link": "shopify://collections/all"
          }
        }
      },
      "block_order": ["eyebrow", "heading", "button"]
    }
  ]
}
{% endschema %}

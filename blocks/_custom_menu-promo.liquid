{%- doc -%}
  Panel promocional del mega menu custom Moxie (ej. NAF&ME: programa de membresía).

  Hijo de `_custom_menu-item` (Fase 2.5 — bloques anidados con guardrails). Agrupa
  `_custom_menu-promo-tier` hijos (Shopify no permite `max_blocks` en el schema de un theme
  block, así que la cantidad no tiene tope explícito).

  Wrapper delgado: todo el markup vive en snippets/custom-menu-promo.liquid.
{%- enddoc -%}

{% capture tiers_content %}
  {% content_for 'blocks' %}
{% endcapture %}

{% render 'custom-menu-promo',
  image: block.settings.image,
  heading: block.settings.heading,
  subheading: block.settings.subheading,
  text: block.settings.text,
  cta_label: block.settings.cta_label,
  cta_link: block.settings.cta_link,
  span_desktop: block.settings.span_desktop,
  tiers_content: tiers_content,
  block_attributes: block.shopify_attributes
%}

{% schema %}
{
  "name": "Moxie Panel promocional",
  "tag": null,
  "blocks": [
    { "type": "_custom_menu-promo-tier" }
  ],
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen lateral"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subtítulo"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Descripción"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texto del botón"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Enlace del botón"
    },
    {
      "type": "select",
      "id": "span_desktop",
      "label": "Ancho relativo en desktop",
      "info": "Peso relativo frente a los demás bloques del ítem.",
      "options": [
        { "value": "6", "label": "6" },
        { "value": "8", "label": "8" },
        { "value": "12", "label": "12" }
      ],
      "default": "8"
    }
  ]
}
{% endschema %}

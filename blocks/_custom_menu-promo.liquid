{%- doc -%}
  Panel promocional del mega menu custom Moxie (ej. NAF&ME: programa de membresía).

  Hijo de `_custom_menu-item`; sus hijos son `_custom_menu-promo-tier` (filas Member/Silver/Black).
  Layout desktop: imagen lateral + columna de texto (título, subtítulo, descripción con bullets,
  CTA) + columna de tiers. En el drawer mobile se apila a una columna (CSS).

  La imagen SIEMPRE lleva width/height explícitos: assets/header-menu.js mide offsetHeight del
  submenu para la animación de apertura.
{%- enddoc -%}

{% liquid
  assign promo_settings = block.settings
%}

<div
  class="custom-menu-promo"
  style="--custom-menu-span: {{ promo_settings.span_desktop | default: 8 }};"
  {{ block.shopify_attributes }}
>
  {%- if promo_settings.image != blank -%}
    <div class="custom-menu-promo__media">
      {{
        promo_settings.image
        | image_url: width: 800
        | image_tag: widths: '320, 480, 640, 800', sizes: '(min-width: 990px) 25vw, 100vw', class: 'custom-menu-promo__image'
      }}
    </div>
  {%- endif -%}

  <div class="custom-menu-promo__body">
    {%- if promo_settings.heading != blank -%}
      <p class="custom-menu-promo__heading">{{ promo_settings.heading }}</p>
    {%- endif -%}
    {%- if promo_settings.subheading != blank -%}
      <p class="custom-menu-promo__subheading">{{ promo_settings.subheading }}</p>
    {%- endif -%}
    {%- if promo_settings.text != blank -%}
      <div class="custom-menu-promo__text rte">{{ promo_settings.text }}</div>
    {%- endif -%}
    {%- if promo_settings.cta_label != blank -%}
      <a
        class="custom-menu-promo__cta button"
        {% if promo_settings.cta_link != blank %}
          href="{{ promo_settings.cta_link }}"
        {% endif %}
      >
        {{ promo_settings.cta_label }}
        <span class="custom-menu-promo__cta-icon">{{ 'icon-chevron-right.svg' | inline_asset_content }}</span>
      </a>
    {%- endif -%}
  </div>

  <div class="custom-menu-promo__tiers">
    {% content_for 'blocks' %}
  </div>
</div>

{% schema %}
{
  "name": "Moxie Panel promocional",
  "tag": null,
  "blocks": [
    {
      "type": "_custom_menu-promo-tier"
    }
  ],
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen lateral"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Naf&Me"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subtítulo",
      "default": "Tu programa de beneficios"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Descripción",
      "default": "<p>Vive una experiencia exclusiva con beneficios, descuentos y acceso a momentos especiales.</p>"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texto del botón",
      "default": "Conoce más"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Enlace del botón"
    },
    {
      "type": "select",
      "id": "span_desktop",
      "label": "Ancho en desktop",
      "options": [
        {
          "value": "6",
          "label": "1/2"
        },
        {
          "value": "8",
          "label": "2/3"
        },
        {
          "value": "12",
          "label": "Completo"
        }
      ],
      "default": "8"
    }
  ]
}
{% endschema %}

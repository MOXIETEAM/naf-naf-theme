{%- comment -%}
  MOXIE: custom hero slider — full-bleed (100% width, sin "peek" de slides vecinos), matching
  el Figma final aprobado (node-id 2140:3812 desktop / 1563:4852 mobile). Versión anterior
  usaba un layout tipo "peek" (stage 64%/86% + paneles laterales clicables) inspirado en
  `slideshow.liquid` display_mode `with_hints`; se retiró porque el Figma no lo contempla.
  La transición sigue siendo crossfade puro (sin scroll/translate lateral) vía el custom
  element `hero-fade-slider` (assets/custom-hero-slider.js), ya que el `slideshow-component`
  nativo siempre se mueve por scroll-snap. Reutiliza sin modificar: slideshow-arrows,
  slideshow-controls (dots/counter), background-media, contrast-override — el
  `on:click="/metodo"` del theme es genérico y no está atado a `slideshow-component`.
{%- endcomment -%}
{% liquid
  assign show_controls = false
  if section.blocks.size > 1
    assign show_controls = true
  endif

  # MOXIE: valores en dvh (no los rem fijos que trae `slideshow.liquid`, pensados
  # para carruseles chicos) — este hero debe sentirse full-bleed en ambos breakpoints,
  # tal como lo muestra el Figma (media ocupa casi todo el alto de viewport).
  assign slide_min_height = '55dvh'
  assign slide_min_height_desktop = '65dvh'
  case section.settings.slide_height
    when 'small'
      assign slide_min_height = '45dvh'
      assign slide_min_height_desktop = '55dvh'
    when 'medium'
      assign slide_min_height = '55dvh'
      assign slide_min_height_desktop = '65dvh'
    when 'large'
      assign slide_min_height = '70dvh'
      assign slide_min_height_desktop = '85dvh'
  endcase
%}

{% capture controls %}
  {% if show_controls %}
    {%- render 'slideshow-controls',
      style: section.settings.slideshow_controls_style,
      autoplay: false,
      item_count: section.blocks.size,
      show_arrows: false,
      arrows_on_media: true,
      controls_on_media: true,
      pagination_position: 'center',
      icon_style: section.settings.icons_style
    -%}
  {% endif %}
{% endcapture %}

{% capture slides %}
  {% content_for 'blocks' %}
{% endcapture %}

{% liquid
  # Content siempre se renderiza sobre la media (on-media): el contraste automático
  # del theme se salta porque cada slide resuelve su propio contraste vía overlay/color.
  render 'contrast-override', background_color: section.settings.background_color, section_id: section.id, skip_contrast: true
%}

<div class="section-background color-custom-{{ section.id }}"></div>
<div
  class="hero-fade-slider-section spacing-style section section--full-width color-custom-{{ section.id }} disable-section-top-offset"
  style="{% render 'spacing-padding', settings: section.settings %}; --corner-radius: {{ section.settings.corner_radius }}px; --slide-min-height: {{ slide_min_height }}; --slide-min-height-desktop: {{ slide_min_height_desktop }};"
>
  <h2 class="visually-hidden">{{ 'accessibility.slideshow' | t }}</h2>

  {% if section.settings.background_media != blank and section.settings.background_media != 'none' %}
    <div class="custom-section-background">
      {% render 'background-media',
        background_media: section.settings.background_media,
        background_image: section.settings.background_image,
        background_image_position: section.settings.background_image_position
      %}
    </div>
  {% endif %}

  <hero-fade-slider
    class="hero-fade-slider"
    {% if section.settings.autoplay %}
      autoplay="{{ section.settings.autoplay_speed }}"
    {% endif %}
  >
    <div class="hero-fade-slider__stage">
      {% if show_controls and section.settings.icons_style != 'none' %}
        {%- render 'slideshow-arrows', icon_style: section.settings.icons_style, icon_shape: section.settings.icons_shape -%}
      {% endif %}
      <div class="hero-fade-slider__slides">
        {{ slides }}
      </div>
      {{ controls }}
    </div>
  </hero-fade-slider>
</div>

<script src="{{ 'custom-hero-slider.js' | asset_url }}" type="module"></script>

{% stylesheet %}
  .hero-fade-slider-section {
    position: relative;
  }

  .hero-fade-slider {
    position: relative;
    display: flex;
    align-items: stretch;
    overflow: hidden;
  }

  .hero-fade-slider__stage {
    position: relative;
    flex: 0 0 auto;
    width: 100%;
    min-height: var(--slide-min-height-desktop);
    border-radius: var(--corner-radius, 0);
    overflow: hidden;
  }

  .hero-fade-slider__slides {
    position: relative;
    width: 100%;
    height: 100%;
  }

  /*
   * MOXIE: el Figma full-bleed no muestra flechas (navegación queda en los dots,
   * `icons_style` default "none"), pero si el merchant las reactiva desde el Theme
   * Editor deben verse en círculo blanco con ícono oscuro — no el hover-reveal nativo
   * de `slideshow-component:hover`, que además está scoped a ese tag y no aplicaría
   * aquí — y no el color de botón primario del tema, que aquí es negro.
   */
  .hero-fade-slider slideshow-arrows .slideshow-control {
    opacity: 1;
  }

  .hero-fade-slider slideshow-arrows .slideshow-control.slideshow-control--shape-circle {
    background-color: var(--color-background);
    color: var(--color-foreground);
  }

  .hero-fade-slider slideshow-arrows .slideshow-control:first-of-type {
    margin-inline-start: var(--padding-xs);
  }

  .hero-fade-slider slideshow-arrows .slideshow-control:last-of-type {
    margin-inline-end: var(--padding-xs);
  }

  @media screen and (max-width: 749px) {
    .hero-fade-slider__stage {
      min-height: var(--slide-min-height);
    }
  }
{% endstylesheet %}


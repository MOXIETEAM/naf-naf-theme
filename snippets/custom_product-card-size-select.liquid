{%- doc -%}
  MOXIE: reemplaza el quick-add nativo en la card para el catálogo NafNaf (solo maneja la opción Talla).
  - Desktop: hover/focus en el botón "+" muestra un overlay de tallas disponibles sobre la imagen;
    clic en una talla agrega esa variante al carrito directo (sin ir a la PDP).
  - Mobile: el mismo botón "+" abre el modal "Compra rápida" (custom_quick-view-modal.liquid) en vez del overlay.

  Los botones de talla usan on:click="product-card-size-select/selectSize" con selector explícito
  (no "/selectSize") porque quedan anidados dentro de <product-form-component>, que también extiende
  Component — el resolver de assets/component.js sube por los ancestros y se queda con el primer
  Component que encuentra, así que sin el selector explícito el click resolvía contra
  product-form-component (sin método selectSize) y no hacía nada, silenciosamente.

  @param {object} product - The product resource
  @param {string} section_id - The section ID, used for the product form
{%- enddoc -%}

{% liquid
  assign variant = product.selected_or_first_available_variant
  # MOXIE: buscar la opción de talla explícita, no asumir que es la primera —
  # productos con otra opción primero (color, etc.) mostrarían esa por error.
  # El catálogo real mezcla nombres "Talla" y "Size" para la misma opción
  # (confirmado contra /collections/mujeres-ropa), así que se matchean ambos.
  assign size_option_talla = product.options_with_values | where: 'name', 'Talla' | first
  assign size_option_size = product.options_with_values | where: 'name', 'Size' | first
  assign size_option = size_option_talla | default: size_option_size
  assign product_form_id = 'CardSizeSelect-ProductForm-' | append: product.id
%}

<product-card-size-select
  class="product-card-size-select"
  data-product-id="{{ product.id }}"
>
  <button
    ref="trigger"
    type="button"
    class="product-card-size-select__trigger quick-add__button"
    aria-label="{{ 'content.select_size_label' | t }}"
    on:click="/handleTriggerClick"
  >
    <span
      class="product-card-size-select__trigger-icon"
      aria-hidden="true"
    >+</span>
  </button>

  <div
    ref="overlay"
    class="product-card-size-select__overlay"
  >
    <product-form-component
      data-section-id="{{ section_id }}"
      data-product-id="{{ product.id }}"
      on:submit="/handleSubmit"
      class="product-card-size-select__form"
    >
      <div
        class="visually-hidden"
        aria-live="assertive"
        role="status"
        aria-atomic="true"
        ref="liveRegion"
      ></div>
      {%- form 'product', product, id: product_form_id, novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
        <input
          type="hidden"
          name="id"
          ref="variantId"
          value="{{ variant.id }}"
        >
        <input
          type="hidden"
          name="quantity"
          value="1"
        >
        <ul class="product-card-size-select__sizes">
          {%- for value in size_option.values -%}
            {%- if value.available -%}
              <li>
                <button
                  type="button"
                  class="product-card-size-select__size"
                  data-variant-id="{{ value.variant.id }}"
                  on:click="product-card-size-select/selectSize"
                >
                  {{- value | escape -}}
                </button>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endform -%}
    </product-form-component>
  </div>
</product-card-size-select>

<script
  src="{{ 'custom-product-card-size-select.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{% stylesheet %}
  /* MOXIE: <product-card-size-select> es un custom element sin display propio
     (inline por default) y sus 2 hijos (trigger, overlay) son position:absolute,
     así que sin esto su caja colapsa a width:0 y el overlay (inset-inline:0)
     hereda ese 0 — hay que anclarlo él mismo al área completa de la imagen. */
  .product-card-size-select {
    position: absolute;
    inset: 0;
    z-index: var(--layer-raised);
    pointer-events: none;
  }

  /* MOXIE: Figma pinta este trigger como un chip gris (#8e8e8e) casi sin radio,
     no la píldora blanca nativa de quick-add — se sobreescribe con doble clase
     para no tocar .quick-add__button en el resto del tema.
     El positioning nativo (inset-inline-end/inset-block-end) depende de custom
     properties (--quick-add-inset-inline-end, etc.) que solo existen dentro del
     wrapper nativo ".quick-add" — como no lo usamos, esas vars quedan inválidas
     y el botón caía en flujo normal (arriba-izq). Se fija un offset propio.
     display/opacity: la clase nativa .quick-add__button usa
     `display: var(--quick-add-mobile-display, none)` y
     `opacity: var(--quick-add-mobile-opacity, 0)` — esas variables las define
     snippets/product-card.liquid nativo (que no usamos), así que sin este
     override el trigger quedaba display:none/opacity:0 en mobile (invisible e
     inaccesible al tap). Se fuerza visible siempre, en ambos breakpoints
     (el chip "+" siempre está visible en el Figma, no solo en hover). */
  .product-card-size-select__trigger.quick-add__button {
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 1;
    width: auto;
    height: auto;
    padding: 4px 7px;
    background: #8e8e8e;
    border: none;
    border-radius: 2px;
    color: #ffffff;
    -webkit-tap-highlight-color: transparent;
    transition:
      opacity 0.15s var(--animation-easing),
      visibility 0.15s;

    @media screen and (max-width: 749px) {
      inset-inline-end: 17px;
      inset-block-end: 15.38px;
    }

    @media screen and (min-width: 750px) {
      inset-inline-end: 24px;
      inset-block-end: 24px;
    }

    &:focus-visible {
      outline: 2px solid var(--color-foreground);
      outline-offset: 2px;
    }
  }

  /* MOXIE: en el Figma el "+" desaparece por completo cuando el overlay de
     tallas se revela — antes quedaba superpuesto sobre el overlay. */
  .product-card-size-select:is(:hover, :focus-within) .product-card-size-select__trigger {
    @media screen and (min-width: 750px) {
      opacity: 0;
      visibility: hidden;
    }
  }

  /* MOXIE: ícono real del Figma — el "+" es texto (Host Grotesk), no un SVG. */
  .product-card-size-select__trigger-icon {
    font-family: var(--font-body--family);
    font-weight: 400;
    font-size: 16px;
    line-height: 0.94;
    letter-spacing: 0;
    vertical-align: middle;
  }

  .product-card-size-select__overlay {
    display: none;

    @media screen and (min-width: 750px) {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 72px;
      position: absolute;
      inset-inline: 0;
      bottom: 0;
      z-index: var(--layer-raised);
      background-color: rgb(var(--color-background-rgb) / var(--opacity-40));
      backdrop-filter: blur(5px);
      opacity: 0;
      visibility: hidden;
      transform: translateY(4px);
      transition:
        opacity 0.15s var(--animation-easing),
        transform 0.15s var(--animation-easing),
        visibility 0.15s;
    }
  }

  .product-card-size-select:is(:hover, :focus-within) .product-card-size-select__overlay {
    @media screen and (min-width: 750px) {
      visibility: visible;
      opacity: 1;
      transform: translateY(0);
      pointer-events: all;
    }
  }

  .product-card-size-select__sizes {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: center;
    gap: clamp(1.5625rem, 2.5vw, 2.25rem);
    margin: 0;
    padding: var(--padding-sm);
    list-style: none;
  }

  .product-card-size-select__size {
    border: none;
    background: none;
    padding: 0;
    color: #000000;
    font-family: var(--font-body--family);
    font-weight: 500;
    font-size: 14px;
    line-height: 1;
    letter-spacing: 0;
    vertical-align: middle;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;

    &:hover {
      text-decoration: underline;
    }

    &:focus-visible {
      outline: 2px solid var(--color-foreground);
      outline-offset: 2px;
    }
  }
{% endstylesheet %}

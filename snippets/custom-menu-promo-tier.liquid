{%- doc -%}
  Fila de tier del panel promocional Moxie (ej. MEMBER / SILVER / BLACK).

  Snippet reutilizado por el tipo fijo "promo" de `_custom_menu-item` (Fase 3 — layouts rígidos,
  reemplaza al antiguo block `_custom_menu-promo-tier`). Ícono + nombre + descripción, con
  divisores entre filas (CSS).

  @param {object} [icon] - Ícono/imagen del tier.
  @param {string} title - Nombre del tier.
  @param {string} [text] - Descripción corta.
  @param {string} [block_attributes] - `block.shopify_attributes` del theme block que renderiza este snippet.
{%- enddoc -%}

<div class="custom-menu-promo-tier" {{ block_attributes }}>
  {%- if icon != blank -%}
    <span class="custom-menu-promo-tier__icon">
      {{ icon | image_url: width: 48 | image_tag: widths: '24, 48', class: 'custom-menu-promo-tier__icon-image' }}
    </span>
  {%- endif -%}
  <span class="custom-menu-promo-tier__title">{{ title }}</span>
  {%- if text != blank -%}
    <span class="custom-menu-promo-tier__text">{{ text }}</span>
  {%- endif -%}
</div>

{% stylesheet %}
  /* Migrado desde src/styles/components/_header-mega-menu.scss, ver docs/css-architecture.md. */
  .custom-menu-promo-tier {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) minmax(0, 2fr);
    align-items: center;
    gap: clamp(10px, 0.97vw, 14px);
    padding-block: clamp(11px, 1.11vw, 16px);
  }

  .custom-menu-promo-tier:not(:first-child) {
    border-block-start: 1px solid rgb(var(--color-foreground-rgb) / 0.12);
  }

  .custom-menu-promo-tier__icon-image {
    display: block;
    width: clamp(17px, 1.67vw, 24px);
    height: clamp(17px, 1.67vw, 24px);
    object-fit: contain;
  }

  .custom-menu-promo-tier__title {
    font-size: clamp(11px, 0.9vw, 13px);
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .custom-menu-promo-tier__text {
    font-size: clamp(11px, 0.9vw, 13px);
    color: rgb(var(--color-foreground-rgb) / 0.75);
  }
{% endstylesheet %}

{%- doc -%}
  Banner de imagen del mega menu custom Moxie (ej. "FASHION EDIT" / "días naf ... 50%dcto").

  Snippet reutilizado por los 4 tipos fijos de `_custom_menu-item` (Fase 3 — layouts rígidos,
  reemplaza al antiguo block `_custom_menu-banner`). Imagen grande con texto overlay (heading +
  texto + CTA opcional). Si hay link, todo el banner es clickeable.

  La imagen SIEMPRE lleva width/height explícitos: assets/header-menu.js mide offsetHeight del
  submenu para la animación de apertura.

  @param {object} [image] - Imagen del banner.
  @param {string} [heading] - Título overlay.
  @param {string} [text] - Texto overlay.
  @param {string} [cta_label] - Texto del CTA visual (sin acción propia, ver comentario en block original).
  @param {string} [link] - Enlace de todo el banner.
  @param {string} content_position - 'bottom-left' | 'center' | 'bottom-right', fijo por tipo.
  @param {number} [span_desktop] - Columnas de la grilla de 12 que ocupa en desktop.
  @param {string} [block_attributes] - `block.shopify_attributes` del theme block que renderiza este snippet.
{%- enddoc -%}

{% liquid
  if link != blank
    assign banner_tag = 'a'
  else
    assign banner_tag = 'div'
  endif
%}

<{{ banner_tag }}
  {% if link != blank %}
    href="{{ link }}"
  {% endif %}
  class="custom-menu-banner"
  style="--custom-menu-span: {{ span_desktop | default: 4 }};"
  {{ block_attributes }}
>
  <div class="custom-menu-banner__media">
    {%- if image != blank -%}
      {{
        image
        | image_url: width: 1000
        | image_tag: widths: '480, 640, 800, 1000', sizes: '(min-width: 990px) 30vw, 100vw', class: 'custom-menu-banner__image'
      }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'custom-menu-banner__image custom-menu-banner__image--placeholder' }}
    {%- endif -%}
  </div>
  {%- if heading != blank or text != blank or cta_label != blank -%}
    <div class="custom-menu-banner__content custom-menu-banner__content--{{ content_position }}">
      {%- if heading != blank -%}
        <p class="custom-menu-banner__heading">{{ heading }}</p>
      {%- endif -%}
      {%- if text != blank -%}
        <p class="custom-menu-banner__text">{{ text }}</p>
      {%- endif -%}
      {%- if cta_label != blank -%}
        <span class="custom-menu-banner__cta">
          {{ cta_label }}
          <span class="custom-menu-banner__cta-icon">{{ 'icon-chevron-right.svg' | inline_asset_content }}</span>
        </span>
      {%- endif -%}
    </div>
  {%- endif -%}
</{{ banner_tag }}>

{% stylesheet %}
  /* Migrado desde src/styles/components/_header-mega-menu.scss, ver docs/css-architecture.md. */
  .custom-menu-banner {
    position: relative;
    display: block;
    overflow: hidden;
    text-decoration: none;
    min-width: 260px;
  }

  /* aspect-ratio fijo — sin esto, una imagen de proporción arbitraria (muy alta o muy
     ancha) descuadraba el alto de la fila frente a los demás bloques hermanos. */
  .custom-menu-banner__media {
    aspect-ratio: 4 / 5;
    height: auto;
  }

  .custom-menu-banner__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .custom-menu-banner__content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
    gap: clamp(7px, 0.69vw, 10px);
    padding: clamp(17px, 1.67vw, 24px);
    color: #ffffff;
  }

  .custom-menu-banner__content--center {
    justify-content: center;
    align-items: center;
    text-align: center;
  }

  .custom-menu-banner__content--bottom-right {
    align-items: flex-end;
    text-align: right;
  }

  .custom-menu-banner__heading {
    margin: 0;
    font-size: clamp(24px, 1.94vw, 28px);
    line-height: 1.15;
  }

  .custom-menu-banner__text {
    margin: 0;
    font-size: clamp(12px, 0.97vw, 14px);
  }

  .custom-menu-banner__cta {
    display: inline-flex;
    align-items: center;
    gap: clamp(6px, 0.56vw, 8px);
    padding: clamp(6px, 0.56vw, 8px) clamp(11px, 1.11vw, 16px);
    border: 1px solid currentColor;
    border-radius: 999px;
    font-size: clamp(11px, 0.9vw, 13px);
  }

  .custom-menu-banner__cta-icon svg {
    display: block;
    width: clamp(8px, 0.83vw, 12px);
    height: clamp(8px, 0.83vw, 12px);
  }
{% endstylesheet %}

{%- doc -%}
  Wishlist toggle button (heart icon) for the product card.
  UI and ARIA state only for now — the toggleWishlist() logic in custom-wishlist.js is a
  stub until the real localStorage-backed wishlist (already built on another store) is migrated here.

  @param {object} product - The product resource
  @param {string} variant - 'mobile' or 'desktop', controls which breakpoint shows this instance

  @example
  {% render 'custom_wishlist-button', product: product, variant: 'mobile' %}
{%- enddoc -%}

<wishlist-button
  class="wishlist-button wishlist-button--{{ variant }}"
  data-product-id="{{ product.id }}"
>
  <button
    ref="button"
    type="button"
    class="wishlist-button__control"
    aria-pressed="false"
    aria-label="{{ 'actions.add_to_wishlist' | t }}"
    on:click="/toggleWishlist"
  >
    <span
      class="svg-wrapper wishlist-button__icon"
      aria-hidden="true"
    >
      {%- if variant == 'mobile' -%}
        {{- 'wishlist-card-mobile.svg' | inline_asset_content -}}
      {%- else -%}
        {{- 'wishlist-card.svg' | inline_asset_content -}}
      {%- endif -%}
    </span>
  </button>
</wishlist-button>

<script
  src="{{ 'custom-wishlist.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{% stylesheet %}
  .wishlist-button__control {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--minimum-touch-target, 2.75rem);
    height: var(--minimum-touch-target, 2.75rem);
    padding: 0;
    border: none;
    background: none;
    color: var(--color-foreground);
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;

    &:focus-visible {
      outline: 2px solid var(--color-foreground);
      outline-offset: 2px;
    }
  }

  /* MOXIE: ícono real del Figma — 18x16 outline (assets/wishlist-card.svg) en desktop;
     20x20 relleno blanco (assets/wishlist-card-mobile.svg, node 1939:4775) en mobile,
     donde el corazón ya viene centrado dentro de su propio viewBox 20x20 para llenar
     el chip gris — no es el mismo dibujo escalado, es la variante "particularidad"
     que mencionó el cliente (fill blanco + stroke fino, no solo outline). */
  .wishlist-button__icon svg {
    width: 18px;
    height: 16px;

    @media screen and (max-width: 749px) {
      width: 20px;
      height: 20px;
    }
  }

  .wishlist-button--desktop {
    display: none;

    @media screen and (min-width: 750px) {
      display: inline-flex;
    }
  }

  .wishlist-button--mobile {
    display: none;

    @media screen and (max-width: 749px) {
      display: inline-flex;
      position: absolute;
      top: 20px;
      right: 17px;
      z-index: var(--layer-raised);
      width: 20px;
      height: 20px;
      border-radius: 1px;
      background-color: #8e8e8e;
    }
  }

  .wishlist-button--mobile .wishlist-button__control {
    width: 20px;
    height: 20px;
  }
{% endstylesheet %}

{%- doc -%}
  MOXIE: modal "Compra rápida" (mobile) — se abre al tocar el "+" de la card
  (ver assets/custom-product-card-size-select.js). Extiende la clase base DialogComponent
  (assets/dialog.js) sin tocarla. Todo el contenido ya está disponible en el producto de la card,
  no requiere fetch como el quick-add nativo.

  La sub-vista "Guía de tallas" está fuera de alcance por ahora (pendiente de que el cliente defina
  la fuente de datos de la tabla de medidas) — el botón queda oculto tras block.settings.show_size_guide.

  @param {object} product - The product resource
  @param {string} section_id - The section ID, used for the product form
  @param {object} [block] - The enclosing _product-card-gallery block, for its low_stock_threshold/show_size_guide settings
{%- enddoc -%}

{% liquid
  assign variant = product.selected_or_first_available_variant
  # MOXIE: buscar la opción "Talla" explícita, no asumir que es la primera —
  # productos con otra opción primero (color, etc.) mostrarían esa por error.
  assign size_option = product.options_with_values | where: 'name', 'Talla' | first
  assign campaign_flag = product.metafields.custom.flag.value
  assign low_stock_threshold = block.settings.low_stock_threshold | default: 3
  assign product_form_id = 'QuickView-ProductForm-' | append: product.id
%}

<custom-quick-view-modal
  id="QuickViewModal-{{ product.id }}"
  class="quick-view-modal-component"
>
  <dialog
    ref="dialog"
    class="quick-view-modal"
    aria-label="{{ 'content.quick_view_title' | t }}"
  >
    <button
      ref="closeButton"
      type="button"
      class="quick-view-modal__close button-unstyled"
      aria-label="{{ 'actions.close' | t }}"
      on:click="/closeDialog"
    >
      {{- 'icon-close.svg' | inline_asset_content -}}
    </button>

    <h2 class="quick-view-modal__title">{{ 'content.quick_view_title' | t }}</h2>

    <div class="quick-view-modal__content">
      <div class="quick-view-modal__media">
        {% render 'product-media',
          media: product.featured_media,
          sizes: '150px',
          loading: 'lazy',
          preview_image_only: true
        %}
      </div>

      <div class="quick-view-modal__details">
        {%- if product.available == false -%}
          <div class="product-badges__badge product-badges__badge--rectangle color-custom-badge-sold-out">
            {{ 'content.product_badge_sold_out' | t }}
          </div>
        {%- elsif campaign_flag != blank -%}
          <div
            class="product-badges__badge product-badges__badge--rectangle"
            style="background-color: {{ campaign_flag.background_color }}; color: {{ campaign_flag.text_color }};"
          >
            {{ campaign_flag.label }}
          </div>
        {%- elsif product.compare_at_price > product.price -%}
          <div class="product-badges__badge product-badges__badge--rectangle color-custom-badge-sale">
            {{ 'content.product_badge_sale' | t }}
          </div>
        {%- endif -%}

        <p class="quick-view-modal__product-title">{{ product.title }}</p>
        {% render 'price', product_resource: product %}
      </div>
    </div>

    <div class="quick-view-modal__size-header">
      <span>{{ 'content.select_size_label' | t }}</span>
      {%- if block.settings.show_size_guide -%}
        <button
          type="button"
          class="button-unstyled quick-view-modal__size-guide"
          on:click="/showSizeGuide"
        >
          {{ 'content.size_guide' | t }}
        </button>
      {%- endif -%}
    </div>

    <product-form-component
      data-section-id="{{ section_id }}"
      data-product-id="{{ product.id }}"
      on:submit="/handleSubmit"
    >
      <div
        class="visually-hidden"
        aria-live="assertive"
        role="status"
        aria-atomic="true"
        ref="liveRegion"
      ></div>
      {%- form 'product', product, id: product_form_id, novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
        <input
          type="hidden"
          name="id"
          ref="variantId"
          value="{{ variant.id }}"
        >
        <input
          type="hidden"
          name="quantity"
          value="1"
        >
        <ul class="quick-view-modal__sizes">
          {%- for value in size_option.values -%}
            <li class="quick-view-modal__size-row">
              <button
                type="button"
                class="quick-view-modal__size-button"
                data-variant-id="{{ value.variant.id }}"
                {% unless value.available %}
                  disabled
                {% endunless %}
                on:click="/selectSize"
              >
                {{- value -}}
              </button>
              <span class="quick-view-modal__size-status">
                {%- if value.available == false -%}
                  {{ 'content.notify_when_available' | t }}
                {%- elsif value.variant.inventory_quantity <= low_stock_threshold and value.variant.inventory_quantity > 0 -%}
                  {{ 'content.last_units_left' | t: count: value.variant.inventory_quantity }}
                {%- endif -%}
              </span>
            </li>
          {%- endfor -%}
        </ul>
      {%- endform -%}
    </product-form-component>
  </dialog>
</custom-quick-view-modal>

<script
  src="{{ 'custom-quick-view-modal.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{% stylesheet %}
  .quick-view-modal {
    padding: var(--padding-xl);
    border: none;
    overflow: hidden auto;
    box-shadow: 0 5px 30px rgb(0 0 0 / var(--opacity-15));

    @media screen and (max-width: 749px) {
      position: fixed;
      margin: auto 0 0 0;
      width: 100%;
      max-width: 100%;
      max-height: 85vh;
      border-radius: 0;
    }

    @media screen and (min-width: 750px) {
      display: none;
    }
  }

  .quick-view-modal[open] {
    border-top-left-radius: var(--style-border-radius-popover);
    border-top-right-radius: var(--style-border-radius-popover);
    animation: quickViewModalSlideIn var(--animation-speed) var(--animation-easing) forwards;
  }

  .quick-view-modal.dialog-closing {
    animation: quickViewModalSlideOut var(--animation-speed) var(--animation-easing) forwards;
  }

  @keyframes quickViewModalSlideIn {
    from {
      transform: translateY(100%);
    }

    to {
      transform: translateY(0);
    }
  }

  @keyframes quickViewModalSlideOut {
    from {
      transform: translateY(0);
    }

    to {
      transform: translateY(100%);
    }
  }

  .quick-view-modal__close {
    position: absolute;
    top: var(--padding-sm);
    right: var(--padding-sm);
    z-index: var(--layer-raised);
    border: none;
    background: none;
    cursor: pointer;
  }

  .quick-view-modal__title {
    margin-block-end: var(--gap-md);
  }

  .quick-view-modal__content {
    display: flex;
    gap: var(--gap-md);
    margin-block-end: var(--gap-lg);
  }

  .quick-view-modal__media {
    flex-shrink: 0;
    width: 6rem;
  }

  .quick-view-modal__details {
    display: flex;
    flex-direction: column;
    gap: var(--gap-2xs);
  }

  .quick-view-modal__size-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-block-end: var(--gap-sm);
  }

  .quick-view-modal__size-guide {
    border: none;
    background: none;
    color: var(--color-foreground);
    text-decoration: underline;
    cursor: pointer;
  }

  .quick-view-modal__sizes {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .quick-view-modal__size-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--padding-xs);
    border-bottom: 1px solid rgb(var(--color-foreground-rgb) / var(--opacity-10));
  }

  .quick-view-modal__size-button {
    border: none;
    background: none;
    padding: 0;
    color: var(--color-foreground);
    font-size: var(--font-size--md);
    text-align: left;
    cursor: pointer;

    &:disabled {
      color: rgb(var(--color-foreground-rgb) / var(--opacity-40));
      cursor: not-allowed;
    }
  }

  .quick-view-modal__size-status {
    color: rgb(var(--color-foreground-rgb) / var(--opacity-60));
    font-size: var(--font-size--xs);
  }
{% endstylesheet %}

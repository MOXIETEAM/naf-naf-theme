{
  "name": "horizon-base-theme",
  "version": "1.0.0",
  "description": "Base Sass + PostCSS workflow for Shopify Horizon themes",
  "scripts": {
    "sass:dev": "cross-env NODE_ENV=development sass src/styles/main.scss assets/mox-custom-styles.css --style=expanded --embed-source-map",
    "post:dev": "cross-env NODE_ENV=development postcss assets/mox-custom-styles.css -o assets/mox-custom-styles.css",
    "build:css": "npm run sass:dev && npm run post:dev",
    "watch:css": "chokidar \"src/styles/**/*.scss\" -c \"npm run build:css\"",
    "sass:prod": "cross-env NODE_ENV=production sass src/styles/main.scss assets/mox-custom-styles.css --no-source-map",
    "post:prod": "cross-env NODE_ENV=production postcss assets/mox-custom-styles.css -o assets/mox-custom-styles.css",
    "build:css:prod": "npm run sass:prod && npm run post:prod",
    "dev:shopify": "npm-run-all --parallel watch:css theme:dev",
    "theme:dev": "dotenv -e .env -- sh -c 'shopify theme dev --store=$SHOPIFY_STORE'"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "chokidar-cli": "^3.0.0",
    "cssnano": "^6.1.2",
    "dotenv-cli": "^7.4.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.49",
    "postcss-cli": "^11.0.0",
    "sass": "^1.77.6",
    "cross-env": "^7.0.3"
  }
}
